diff --git a/.github/workflows/build-image-only.yml b/.github/workflows/build-image-only.yml
new file mode 100644
index 0000000000..9e5ae2ccff
--- /dev/null
+++ b/.github/workflows/build-image-only.yml
@@ -0,0 +1,344 @@
+name: Build image only (fast-iter)
+
+# Fast-iter workflow for changes that ONLY touch the install / image
+# step (e.g. rocknix-guest-substrate/package.mk, rocknix-guest-substrate scripts,
+# system.d units, profile.d files, post_install logic). Reuses the
+# heavy artifacts -- toolchain, aarch64, arm, mame-lr, qt6,
+# emu-libretro, emu-standalone -- from a previous successful "Build"
+# run on the same DEVICE, then runs ONLY the image step. Cuts the
+# wall time from ~5h to ~30 min.
+#
+# Pre-requisites:
+#   1. The base run must have completed successfully and its
+#      artifacts must still exist (the "Build" workflow's cleanup
+#      step skips deletion on feature branches; verify in the
+#      run's Artifacts panel).
+#   2. The base run must be for the same DEVICE you want to image.
+
+on:
+  workflow_dispatch:
+    inputs:
+      BASE_RUN_ID:
+        description: "Run ID of a successful 'Build' run on this branch (numeric, e.g. 25541232603). Find it under Actions -> Build."
+        required: true
+        type: string
+      DEVICE:
+        description: "Target device"
+        required: true
+        default: "SM8550"
+        type: choice
+        options:
+          - SM8550
+          - SM8650
+          - SM8250
+          - SM6115
+          - RK3326
+          - RK3399
+          - RK3566
+          - RK3576
+          - RK3588
+          - S922X
+          - H700
+      CLEAN_GUEST_SUBSTRATE:
+        description: "Force re-run of rocknix-guest-substrate's post_install by cleaning that package before image"
+        required: false
+        default: true
+        type: boolean
+
+jobs:
+  build-image-only:
+    runs-on: ubuntu-24.04
+    permissions:
+      actions: read
+      contents: read
+    env:
+      JAVA_HOME: /usr
+      PROJECT: ROCKNIX
+      DEVICE: ${{ inputs.DEVICE }}
+      ARCH: aarch64
+      DISABLE_COLORS: yes
+      CCACHE_COMPILERCHECK: content
+      CCACHE_COMPRESS: 1
+      CCACHE_COMPRESSLEVEL: 6
+      CCACHE_SLOPPINESS: pch_defines,time_macros,include_file_mtime,include_file_ctime
+      CHEEVOS_DEV_LOGIN: ${{ secrets.CHEEVOS_DEV_LOGIN }}
+      GAMESDB_APIKEY: ${{ secrets.GAMESDB_APIKEY }}
+      SCREENSCRAPER_DEV_LOGIN: ${{ secrets.SCREENSCRAPER_DEV_LOGIN }}
+      NIGHTLY: yes
+      OFFICIAL: no
+      GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+      GH_REPO: ${{ github.repository }}
+      BASE_RUN_ID: ${{ inputs.BASE_RUN_ID }}
+      CLEAN_GUEST_SUBSTRATE: ${{ inputs.CLEAN_GUEST_SUBSTRATE }}
+    steps:
+      - name: Maximize build space
+        uses: justinthelaw/maximize-github-runner-space@v0.7.0
+        with:
+          skip-components: docker-engine
+
+      # The maximize-github-runner-space action strips /opt/hostedtoolcache
+      # and several pre-installed tools. gh is among them. Re-install
+      # before any step uses `gh api` / `gh run download`.
+      - name: Re-install gh CLI (stripped by maximize step)
+        run: |
+          set -euo pipefail
+          if command -v gh >/dev/null 2>&1; then
+            echo "gh already present: $(gh --version | head -1)"
+          else
+            (type -p wget >/dev/null || sudo apt-get install -y wget)
+            sudo mkdir -p -m 755 /etc/apt/keyrings
+            wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
+              sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null
+            sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
+            echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | \
+              sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
+            sudo apt-get update -qq
+            sudo apt-get install -y -qq gh
+            gh --version | head -1
+          fi
+
+      - uses: actions/checkout@v6
+        with:
+          fetch-depth: 0
+
+      - name: Run build integrity checks
+        shell: bash
+        run: |
+          set -euo pipefail
+          git fetch --no-tags https://github.com/ROCKNIX/distribution.git \
+            next:refs/remotes/upstream/next
+          projects/ROCKNIX/packages/tools/rocknix-guest-substrate/tests/guest-substrate-static-checks.sh
+          git diff --check upstream/next...HEAD
+
+      - name: Verify base run is on the same branch and successful
+        run: |
+          set -euo pipefail
+          run_json=$(gh api "repos/${GH_REPO}/actions/runs/${BASE_RUN_ID}")
+          base_branch=$(echo "${run_json}" | jq -r '.head_branch // empty')
+          base_status=$(echo "${run_json}" | jq -r '.conclusion')
+          base_workflow=$(echo "${run_json}" | jq -r '.name')
+          base_sha=$(echo "${run_json}" | jq -r '.head_sha // empty')
+          current_branch="${GITHUB_REF_NAME}"
+          current_sha="$(git rev-parse HEAD)"
+          echo "base run: ${BASE_RUN_ID}"
+          echo "  workflow:    ${base_workflow}"
+          echo "  branch:      ${base_branch:-<empty>}"
+          echo "  sha:         ${base_sha:-<empty>}"
+          echo "  status:      ${base_status}"
+          echo "current run:"
+          echo "  branch:      ${current_branch}"
+          echo "  sha:         ${current_sha}"
+          if [ "${base_status}" != "success" ]; then
+            echo "::error::base run ${BASE_RUN_ID} did not succeed (status=${base_status})"
+            exit 1
+          fi
+          if [ "${base_workflow}" != "Build" ]; then
+            echo "::error::base run ${BASE_RUN_ID} is not a 'Build' workflow run (was '${base_workflow}')"
+            exit 1
+          fi
+          if [ -z "${base_branch}" ] || [ "${base_branch}" = "null" ]; then
+            echo "::error::base run ${BASE_RUN_ID} has no branch; fast-iter artifact reuse is branch-only"
+            exit 1
+          fi
+          if [ "${base_branch}" != "${current_branch}" ]; then
+            echo "::error::base run ${BASE_RUN_ID} is on branch '${base_branch}', but this workflow is running '${current_branch}'"
+            exit 1
+          fi
+          if [ -z "${base_sha}" ] || [ "${base_sha}" = "null" ]; then
+            echo "::error::base run ${BASE_RUN_ID} has no head SHA"
+            exit 1
+          fi
+          if ! git cat-file -e "${base_sha}^{commit}" 2>/dev/null; then
+            echo "::error::base run SHA ${base_sha} is not present in the checked-out history"
+            exit 1
+          fi
+          if ! git merge-base --is-ancestor "${base_sha}" HEAD; then
+            echo "::error::base run SHA ${base_sha} is not an ancestor of current SHA ${current_sha}"
+            exit 1
+          fi
+
+          changed_paths="$(git diff --name-only "${base_sha}..HEAD")"
+          if [ -n "${changed_paths}" ]; then
+            echo "changed paths since base run:"
+            printf '%s\n' "${changed_paths}" | sed 's/^/  /'
+          else
+            echo "changed paths since base run: none"
+          fi
+
+          unsafe_changes="$(printf '%s\n' "${changed_paths}" | grep -Ev '^(\.github/workflows/(build-image-only|build-nightly)\.yml|scripts/(local-image-build|image|mkimage)|projects/ROCKNIX/packages/sysutils/busybox/scripts/init|projects/ROCKNIX/devices/SM8550/options|projects/ROCKNIX/packages/tools/rocknix-guest-substrate/(package\.mk|scripts/.*|system\.d/.*|tests/.*))$' || true)"
+          if [ -n "${unsafe_changes}" ]; then
+            echo "::error::base run is stale for this checkout; changed paths are not image-step-safe. Run a full Build first."
+            printf '%s\n' "${unsafe_changes}" | sed 's/^/  /'
+            exit 1
+          fi
+
+          guest_substrate_changes="$(printf '%s\n' "${changed_paths}" | grep -E '^projects/ROCKNIX/packages/tools/rocknix-guest-substrate/(package\.mk|scripts/|system\.d/|tests/)' || true)"
+          if [ -n "${guest_substrate_changes}" ] && [ "${CLEAN_GUEST_SUBSTRATE}" != "true" ]; then
+            echo "::error::guest-substrate package/script/unit/test changes require CLEAN_GUEST_SUBSTRATE=true"
+            printf '%s\n' "${guest_substrate_changes}" | sed 's/^/  /'
+            exit 1
+          fi
+
+      - name: Download aarch64 artifact from base run
+        if: ${{ inputs.DEVICE == 'SM8550' }}
+        run: |
+          set -euo pipefail
+          gh run download "${BASE_RUN_ID}" --name "aarch64 (${DEVICE})" --dir .
+          tar -xf build.aarch64.tar
+          rm build.aarch64.tar
+
+      - name: Download aarch64 build artifact from base run
+        if: ${{ inputs.DEVICE == 'SM8550' }}
+        run: |
+          set -euo pipefail
+          gh run download "${BASE_RUN_ID}" --name "aarch64 build (${DEVICE})" --dir .
+          tar -xf build.build.aarch64.tar
+          rm build.build.aarch64.tar
+
+      - name: Download arm artifact from base run
+        if: ${{ inputs.DEVICE != 'SM8650' && inputs.DEVICE != 'SM8550' }}
+        run: |
+          set -euo pipefail
+          gh run download "${BASE_RUN_ID}" --name "arm (${DEVICE})" --dir .
+          tar --zstd -xf build.arm.tar.zst
+          rm build.arm.tar.zst
+
+      - name: Download emu-libretro artifact from base run
+        if: ${{ inputs.DEVICE != 'SM8550' }}
+        run: |
+          set -euo pipefail
+          gh run download "${BASE_RUN_ID}" --name "emu-libretro (${DEVICE})" --dir .
+          cat build.emu-libretro.tar.part* > build.emu-libretro.tar
+          tar -xf build.emu-libretro.tar
+          rm build.emu-libretro.tar*
+
+      - name: Download emu-standalone artifact from base run
+        if: ${{ inputs.DEVICE != 'SM8550' }}
+        run: |
+          set -euo pipefail
+          gh run download "${BASE_RUN_ID}" --name "emu-standalone (${DEVICE})" --dir .
+          cat build.emu-standalone.tar.part* > build.emu-standalone.tar
+          tar --skip-old-files -xf build.emu-standalone.tar
+          rm build.emu-standalone.tar*
+
+      # Need ${OWNER_LC} for the docker image tag.
+      - name: Set lowercase owner name
+        id: owner
+        run: echo "OWNER_LC=$(echo '${{ github.repository_owner }}' | tr A-Z a-z)" >> $GITHUB_OUTPUT
+
+      # Force a re-run of rocknix-guest-substrate's post_install by removing
+      # its install_pkg checkpoint. The build_distro detects the
+      # missing stamp and re-installs (no recompile needed since
+      # PKG_TOOLCHAIN="manual"). Without this, post_install changes
+      # would not take effect.
+      - name: Clean rocknix-guest-substrate to force post_install re-run
+        if: ${{ inputs.CLEAN_GUEST_SUBSTRATE }}
+        run: |
+          ./scripts/get_env > .env
+          docker run --init --env-file .env --rm --user $(id -u):$(id -g) \
+            -v ${PWD}:${PWD} -w ${PWD} \
+            "ghcr.io/${{ steps.owner.outputs.OWNER_LC }}/rocknix-build:latest" \
+            bash -c "./scripts/clean rocknix-guest-substrate"
+
+      - name: build
+        run: |
+          ./scripts/get_env > .env
+          set -e
+          { docker run --init --env-file .env --rm --user $(id -u):$(id -g) \
+              -v ${PWD}:${PWD} -w ${PWD} \
+              "ghcr.io/${{ steps.owner.outputs.OWNER_LC }}/rocknix-build:latest" \
+              bash -c "./scripts/build_distro"; echo $? > docker_exit_code; } \
+            | tee output.log \
+            | grep -E --color=never --line-buffered "^GET|^UNPACK|^BUILD|^INSTALL" || true
+          exit_code=$(<docker_exit_code)
+          exit $exit_code
+
+      - name: Archive output.logs on failure
+        if: failure()
+        uses: actions/upload-artifact@v7
+        with:
+          name: output.logs (${{ inputs.DEVICE }}-image-only)
+          path: |
+            output.log
+            ./build.ROCKNIX-${{ inputs.DEVICE }}.aarch64/.threads/logs/
+
+      - name: Verify SM8550 host and seed artifacts
+        if: ${{ inputs.DEVICE == 'SM8550' }}
+        run: |
+          set -euo pipefail
+          budget_mib="$(sed -n -e 's/.*SM8550_FLASH_PARTITION_BUDGET_MIB:-\([0-9][0-9]*\).*/\1/p' -e 's/^[[:space:]]*SM8550_FLASH_PARTITION_BUDGET_MIB="\{0,1\}\([0-9][0-9]*\).*/\1/p' projects/ROCKNIX/devices/SM8550/options | head -1)"
+          if [ -z "${budget_mib}" ]; then
+            echo "unable to parse SM8550_FLASH_PARTITION_BUDGET_MIB" >&2
+            exit 1
+          fi
+          budget_bytes="$((budget_mib * 1024 * 1024))"
+          update_tars="$(find target -maxdepth 1 -name 'ROCKNIX-*.tar' | sort)"
+          update_tar_count="$(printf '%s\n' "${update_tars}" | sed '/^$/d' | wc -l | tr -d ' ')"
+          if [ "${update_tar_count}" -ne 1 ]; then
+            echo "expected exactly one SM8550 update tar, found ${update_tar_count}" >&2
+            exit 1
+          fi
+          update_tar="${update_tars}"
+          system_bytes="$(tar -tvf "${update_tar}" | awk '$NF ~ /(^|\/)target\/SYSTEM$/ { print $3; exit }')"
+          if [ -z "${system_bytes}" ]; then
+            echo "${update_tar} does not contain target/SYSTEM" >&2
+            exit 1
+          fi
+          if [ "${system_bytes}" -gt "${budget_bytes}" ]; then
+            echo "${update_tar} target/SYSTEM exceeds SM8550 SYSTEM budget: ${system_bytes} > ${budget_bytes}" >&2
+            exit 1
+          fi
+          expected_seed="$(sed -n 's/^PKG_NIX_GUEST_ROOTFS_SEED_ARCHIVE="\{0,1\}\([^" ]*\)"\{0,1\}$/\1/p' projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk | sed -n '1p')"
+          expected_seed_sha="$(sed -n 's/^PKG_NIX_GUEST_ROOTFS_SEED_SHA256="\{0,1\}\([^" ]*\)"\{0,1\}$/\1/p' projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk | sed -n '1p')"
+          if [ -z "${expected_seed}" ] || [ -z "${expected_seed_sha}" ]; then
+            echo "unable to parse expected SM8550 guest seed archive/SHA256" >&2
+            exit 1
+          fi
+          seed_entry="$(tar -tf "${update_tar}" | awk -v want="target/seed/${expected_seed}" '{ suffix="/" want; if ($0 == want || (length($0) >= length(suffix) && substr($0, length($0) - length(suffix) + 1) == suffix)) { print; exit } }')"
+          if [ -z "${seed_entry}" ]; then
+            echo "${update_tar} missing expected SM8550 guest seed payload: target/seed/${expected_seed}" >&2
+            exit 1
+          fi
+          actual_seed_sha="$(tar -xOf "${update_tar}" "${seed_entry}" | sha256sum | awk '{print $1}')"
+          if [ "${actual_seed_sha}" != "${expected_seed_sha}" ]; then
+            echo "${update_tar}:${seed_entry} SHA256 mismatch: ${actual_seed_sha} != ${expected_seed_sha}" >&2
+            exit 1
+          fi
+          tar -tf "${update_tar}" | grep -Eq '(^|/)target/SYSTEM$'
+          for image in target/ROCKNIX-*.img.gz; do
+            gzip -t "${image}"
+          done
+          for checksum in target/ROCKNIX-*.img.gz.sha256 target/ROCKNIX-*.tar.sha256; do
+            [ -f "${checksum}" ] || continue
+            (cd target && sha256sum -c "$(basename "${checksum}")")
+          done
+
+      - name: Get date
+        run: echo "DATE=$(date +'%Y%m%d')" >> $GITHUB_ENV
+
+      - name: Compute artifact suffix
+        id: artifact-suffix
+        run: |
+          if [ "${DEVICE}" = "SM8550" ]; then
+            echo "suffix=-thin-host" >> $GITHUB_OUTPUT
+          else
+            echo "suffix=" >> $GITHUB_OUTPUT
+          fi
+
+      - uses: actions/upload-artifact@v7
+        with:
+          name: ROCKNIX-image-${{ inputs.DEVICE }}${{ steps.artifact-suffix.outputs.suffix }}-${{ env.DATE }}-fastiter
+          path: |
+            target/ROCKNIX-*.img.gz
+            target/ROCKNIX-*.img.gz.sha256
+          compression-level: 0
+          if-no-files-found: error
+
+      - uses: actions/upload-artifact@v7
+        with:
+          name: ROCKNIX-update-${{ inputs.DEVICE }}${{ steps.artifact-suffix.outputs.suffix }}-${{ env.DATE }}-fastiter
+          path: |
+            target/ROCKNIX-*.tar
+            target/ROCKNIX-*.tar.sha256
+          compression-level: 0
+          if-no-files-found: error
