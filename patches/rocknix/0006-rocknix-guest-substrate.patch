diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service
new file mode 100644
index 0000000000..e6102c0606
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service
@@ -0,0 +1,185 @@
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# SM8550 guest: NixOS main-space guest unit.
+#
+# This unit replaces the experimental broad-bind unit from the Tier A-E
+# spike series. The shopping list applied here is the direct lesson
+# of those spikes:
+#
+#   - NO host /usr leak  -> drop --bind-ro=/usr (Vulkan/EGL ICD pollution,
+#                           Mesa store-path mismatch)
+#   - NO host /lib leak  -> drop --bind-ro=/lib  (same class of pollution)
+#   - NO /etc/profile leak -> drop --bind-ro=/etc/profile{,/.d}
+#                             (PATH clobber from 098-busybox)
+#   - NO /etc/resolv.conf bind -> guest owns its own resolv.conf
+#                                 (host resolvconf was clobbering guest DNS)
+#   - NO /run/0-runtime-dir bind -> guest runs its own wayland compositor
+#   - NO /tmp/.X11-unix bind     -> guest does not need host X11
+#   - NO /etc/ssh/authorized_keys.d bind -> guest SSH, when enabled in
+#                                           the guest, owns its own keys
+#   - NO product storage binds -> guest owns product state and media mounting;
+#                                  host exposes only the nix-on-rock exchange
+#                                  as guest-visible /storage/.guest during transition
+#
+# Network:
+#   --register=no  -> avoid host machinectl coupling
+#   no --private-network -> shared host netns; guest's NetworkManager owns
+#                           wlan0 directly (Tier C finding)
+#
+# Storage:
+#   Host owns substrate storage: /flash, /storage, /nix, /storage/.update,
+#   and /storage/nix-on-rock. The guest owns game/media mounting.
+#   rocknix-guest-start discovers safe non-host-mounted game/media block
+#   devices, applies exact runtime DeviceAllow entries for those nodes, and
+#   passes them through at launch. Do not use broad block DeviceAllow classes:
+#   nspawn/devtmpfs can still expose host block nodes inside the guest.
+#
+# Lifecycle:
+#   ExecStartPre resolves the selected guest generation from the guest rootfs
+#     profile /nix/var/nix/profiles/per-user/root/rocknix-guest-system.
+#     /nix/var/nix/profiles/system is no longer a host boot authority.
+#   Restart=on-failure lets systemd retry the guest, but StartLimit* bounds
+#     bad-generation crash loops. If it remains broken, explicit recovery uses
+#     /flash/rocknix.no-nspawn or rocknix.safe=1; we do not resurrect the
+#     legacy host UI automatically.
+#
+# This unit is enabled on SM8550 via Wants= on rocknix-main-space.target.
+
+[Unit]
+Description=ROCKNIX SM8550 guest (NixOS main-space)
+Documentation=file:///usr/lib/rocknix-guest-substrate/docs/layer14-main-space-contract.md
+Requires=rocknix-guest-root-ensure.service
+After=local-fs.target network-pre.target rocknix-guest-root-ensure.service
+RequiresMountsFor=/storage /flash
+ConditionKernelCommandLine=!rocknix.safe=1
+ConditionPathExists=!/flash/rocknix.no-nspawn
+ConditionPathExists=/usr/bin/systemd-nspawn
+StartLimitIntervalSec=5min
+StartLimitBurst=3
+StartLimitAction=none
+
+[Service]
+Type=notify
+NotifyAccess=all
+KillMode=mixed
+Delegate=yes
+TasksMax=4096
+# DeviceAllow entries must cover every host device the guest compositor and
+# guest daemons open. Adding /dev/net/tun alone for Tailscale narrows the
+# service cgroup enough that wlroots/libseat cannot open the VT/DRM/input
+# devices even though they are bound into the container. Use explicit device
+# nodes here: systemd-255 does not apply the wildcard forms reliably enough
+# for wlroots/libseat's DRM open path on Thor.
+DeviceAllow=/dev/net/tun rwm
+# BLE HID-over-GATT devices need uhid so guest bluetoothd can create kernel
+# input devices for paired mice/keyboards.
+DeviceAllow=/dev/uhid rwm
+DeviceAllow=/dev/snd/controlC0 rwm
+DeviceAllow=/dev/snd/pcmC0D0p rwm
+DeviceAllow=/dev/snd/pcmC0D1p rwm
+DeviceAllow=/dev/snd/pcmC0D2c rwm
+DeviceAllow=/dev/snd/timer rwm
+# The guest owns ALSA/PipeWire policy; allow the ALSA character class so the
+# guest can keep owning audio if the kernel exposes additional sound nodes.
+DeviceAllow=char-alsa rwm
+DeviceAllow=/dev/dri/card0 rwm
+DeviceAllow=/dev/dri/renderD128 rwm
+DeviceAllow=/dev/input/event0 rwm
+DeviceAllow=/dev/input/event1 rwm
+DeviceAllow=/dev/input/event2 rwm
+DeviceAllow=/dev/input/event3 rwm
+DeviceAllow=/dev/input/event4 rwm
+DeviceAllow=/dev/input/event5 rwm
+DeviceAllow=/dev/input/event6 rwm
+DeviceAllow=/dev/input/event7 rwm
+DeviceAllow=/dev/input/event8 rwm
+DeviceAllow=/dev/input/event9 rwm
+DeviceAllow=/dev/input/event10 rwm
+DeviceAllow=/dev/input/event11 rwm
+DeviceAllow=/dev/input/event12 rwm
+# Keep exact built-in event nodes for the known SM8550 layout, but also allow
+# the kernel input classes so USB-C keyboard/gamepad hotplug is not hostage to
+# event-number ordering after cold boot.
+DeviceAllow=char-input rwm
+DeviceAllow=char-hidraw rwm
+DeviceAllow=/dev/uinput rwm
+DeviceAllow=/dev/tty0 rwm
+DeviceAllow=/dev/tty1 rwm
+DeviceAllow=/dev/rfkill rwm
+# qcom-iris (SM8550) exposes /dev/video0 (decoder) + /dev/video1 (encoder)
+# at probe time. The rocknix-guest-start script binds whichever video[0-9]*
+# nodes the kernel registered into the container; this class allow is the
+# cgroup companion. Without it, the bind succeeds but every open() inside the
+# guest returns EPERM and Moonlight's v4l2m2m enumeration finds nothing.
+DeviceAllow=char-video4linux rwm
+# /dev/ntsync (kernel >= 6.10) lets Wine/Proton emulate Win32 sync
+# primitives natively. Big perf win for Steam Proton games on SM8550.
+# Harmless when the device is absent.
+DeviceAllow=/dev/ntsync rwm
+# /dev/drm_dp_aux0 carries DisplayPort AUX traffic for the card0-DP-1
+# connector (USB-C DP-alt-mode). Required for external display EDID/HPD.
+DeviceAllow=/dev/drm_dp_aux0 rwm
+# /dev/cpu_dma_latency: PM QoS latency floor. Steam/gamescope/wine open
+# it to keep deeper CPU C-states out of an active game/stream session.
+# Harmless when no consumer is running.
+DeviceAllow=/dev/cpu_dma_latency rwm
+# Qualcomm Hexagon DSP RPC endpoints (SM8550). Guest workloads that
+# offload audio / compute / camera ISP work to the DSP need direct
+# access. Harmless when no consumer is running in the guest.
+DeviceAllow=/dev/fastrpc-adsp rwm
+DeviceAllow=/dev/fastrpc-cdsp rwm
+DeviceAllow=/dev/fastrpc-cdsp-secure rwm
+
+# Game/media storage is passed by rocknix-guest-start after excluding any
+# block root that backs mounted host filesystems. Keep block DeviceAllow exact
+# and runtime-generated there; broad block classes expose host substrate disks.
+
+# Force unified cgroup hierarchy inside the guest container. The host
+# kernel cmdline sets systemd.unified_cgroup_hierarchy=1, but
+# systemd-nspawn from systemd-255 (host) still mounts a cgroup-v1 view
+# inside the container by default for legacy compat. The guest's
+# systemd-258 refuses to run on legacy v1 hierarchy and aborts with
+# "Detected unsupported legacy cgroup hierarchy, refusing execution."
+#
+# Validated on Thor 2026-05-08: without this env, the guest aborts
+# at PID 1; with it, the guest reaches Multi-User System target.
+Environment=SYSTEMD_NSPAWN_UNIFIED_HIERARCHY=1
+
+# Bound the guest so host recovery remains responsive.
+CPUWeight=100
+IOWeight=100
+MemoryMax=6G
+
+WorkingDirectory=/storage/nix-on-rock/rootfs/current
+
+# Clear persisted host rfkill state before the guest inherits the shared
+# network namespace. systemd-rfkill stores state under /storage on ROCKNIX, so
+# stale Wi-Fi soft-blocks otherwise survive reboot and leave the guest with
+# wlan0 unavailable.
+ExecStartPre=/usr/bin/rocknix-guest-wifi-unblock --host-only
+
+# Seed /run/current-system + /run/booted-system; touch the resolv.conf
+# ownership marker; verify the rootfs is shaped for SM8550 guest.
+ExecStartPre=/usr/bin/rocknix-guest-prep
+
+# Guest udev and InputPlumber now own input classification and hide-by-move.
+# The legacy rocknix-guest-udev-stage helper remains installed for one
+# safety-net release, but is no longer wired into the normal cold-boot path.
+# SSH rollback uses a disabled drop-in staged under /storage by package.mk.
+
+ExecStart=/usr/bin/rocknix-guest-start
+
+Restart=on-failure
+RestartSec=2s
+TimeoutStartSec=60s
+TimeoutStopSec=30s
+WatchdogSec=30s
+
+StandardOutput=journal
+StandardError=journal
+
+[Install]
+# Intentionally NOT WantedBy=multi-user.target; this unit is owned by the
+# SM8550 main-space target instead.
+WantedBy=rocknix-main-space.target
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-main-space.target b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-main-space.target
new file mode 100644
index 0000000000..2f44a17b45
