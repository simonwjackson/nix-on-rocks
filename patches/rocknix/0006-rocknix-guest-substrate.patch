+NIX_ON_ROCK_REQUESTS_DIR="${ROCKNIX_NIX_ON_ROCK_REQUESTS_DIR:-${NIX_ON_ROCK_ROOT}/requests}"
+NIX_ON_ROCK_STATE_DIR="${ROCKNIX_NIX_ON_ROCK_STATE_DIR:-${NIX_ON_ROCK_ROOT}/state}"
+NIX_ON_ROCK_STAGING_DIR="${ROCKNIX_NIX_ON_ROCK_STAGING_DIR:-${NIX_ON_ROCK_ROOT}/staging}"
+NIX_ON_ROCK_GUEST_EXCHANGE_DIR="${ROCKNIX_GUEST_AREA:-${NIX_ON_ROCK_STAGING_DIR}/guest-exchange}"
+NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH="${ROCKNIX_GUEST_AREA_GUEST_PATH:-/storage/.guest}"
+
+NIX_ON_ROCK_MANUAL_HOLD_FILE="${ROCKNIX_GUEST_MANUAL_HOLD_FILE:-${NIX_ON_ROCK_REQUESTS_DIR}/manual-generation-hold}"
+NIX_ON_ROCK_SWITCH_STATE_FILE="${ROCKNIX_GUEST_SWITCH_STATE:-${NIX_ON_ROCK_STATE_DIR}/generation-switch-a}"
+NIX_ON_ROCK_IMPORT_PROVENANCE_FILE="${ROCKNIX_GUEST_IMPORT_PROVENANCE:-${NIX_ON_ROCK_STAGING_DIR}/generation-import-candidate}"
+NIX_ON_ROCK_STAGED_SOURCE="${ROCKNIX_GUEST_STAGED_SOURCE:-${NIX_ON_ROCK_GUEST_EXCHANGE_DIR}/rocknix-nix-guest-packaged}"
+NIX_ON_ROCK_PROMOTE_SYSTEM_PATH_FILE="${ROCKNIX_GUEST_PROMOTE_SYSTEM_PATH:-${NIX_ON_ROCK_GUEST_EXCHANGE_DIR}/rocknix-guest-promote-system-path}"
+
+NIX_ON_ROCK_LAYOUT_VERSION_FILE="${ROCKNIX_NIX_ON_ROCK_LAYOUT_VERSION_FILE:-${NIX_ON_ROCK_STATE_DIR}/layout-version}"
+NIX_ON_ROCK_MIGRATION_IN_PROGRESS="${ROCKNIX_NIX_ON_ROCK_MIGRATION_IN_PROGRESS:-${NIX_ON_ROCK_STAGING_DIR}/layout-migration-in-progress}"
