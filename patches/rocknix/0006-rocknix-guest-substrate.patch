diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk
new file mode 100644
index 0000000000..51ff27c47f
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk
@@ -0,0 +1,278 @@
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+
+PKG_NAME="rocknix-guest-substrate"
+PKG_VERSION="0"
+PKG_LICENSE="GPL-2.0"
+PKG_SITE="https://github.com/ROCKNIX/distribution"
+PKG_URL=""
+PKG_DEPENDS_TARGET="toolchain"
+PKG_LONGDESC="rocknix-guest-substrate: SM8550 main-space guest substrate for ROCKNIX"
+PKG_TOOLCHAIN="manual"
+
+# Pinned source of the NixOS main-space guest. The host repo carries
+# only the substrate plumbing for the guest; the product appliance source lives
+# in Korri and is fetched from a pinned product commit at build time.
+# Bump PKG_NIX_GUEST_REV (and the accompanying
+# SHA256 of the GitHub-rendered tarball) to roll the host to a newer guest
+# release. The closure layout dropped into /usr/lib/rocknix-guest-substrate/guest/
+# remains the same; only the product authority source moved to Korri.
+PKG_NIX_GUEST_AUTHORITY_REPO="simonwjackson/korri"
+PKG_NIX_GUEST_AUTHORITY_NAME="${PKG_NIX_GUEST_AUTHORITY_REPO##*/}"
+PKG_NIX_GUEST_REV="4d6aaa443809bc6e9551278e020f93b4cf230469"
+PKG_NIX_GUEST_SHA256="6c312a2ad0d3654d0c6fb3d6fa91254d5c2860883a7c5872dd9507d7fb3d925d"
+PKG_NIX_GUEST_URL="https://api.github.com/repos/${PKG_NIX_GUEST_AUTHORITY_REPO}/tarball/${PKG_NIX_GUEST_REV}"
+PKG_NIX_GUEST_SOURCE_SUBDIR="."
+PKG_NIX_GUEST_BUILD_TARGET=".#nixosConfigurations.korri-rocknix-kiosk-by-compatible.config.system.build.toplevel"
+
+# Bootable first-boot guest rootfs seed. This is intentionally distinct from
+# PKG_NIX_GUEST_URL: packaged Korri source can be promoted by a running guest,
+# but fresh /storage needs a prebuilt bootable rootfs seed before
+# rocknix-guest.service can start. Until Korri publishes canonical seed assets,
+# this lock records the archived fallback seed revision and SHA explicitly.
+# Leave placeholders unset only while developing the substrate; post_install
+# fails closed until a real URL and SHA256 are provided.
+PKG_NIX_GUEST_ROOTFS_SEED_REV="d5d00fe4b58822da8ab0a0c21ea4306a92c65c2a"
+PKG_NIX_GUEST_ROOTFS_SEED_DEVICE="thor"
+PKG_NIX_GUEST_ROOTFS_SEED_COMPATIBLE="ayn,thor"
+PKG_NIX_GUEST_ROOTFS_SEED_ARCHIVE="rocknix-guest-rootfs-thor-d5d00fe4b588.tar.zst"
+PKG_NIX_GUEST_ROOTFS_SEED_SHA256="0ff2b8c4bbe400d4f9445c6f4350f126d826fa7321f6f9e11d97f32987c8d9bb"
+PKG_NIX_GUEST_ROOTFS_SEED_URL=""
+PKG_NIX_GUEST_ROOTFS_SEED_URLS="https://api.github.com/repos/simonwjackson/nix-on-rocks/releases/assets/426703720 https://api.github.com/repos/simonwjackson/nix-on-rocks/releases/assets/426704444"
+
+github_token() {
+  printf '%s' "${GITHUB_TOKEN:-${GH_TOKEN:-}}"
+}
+
+curl_fetch() {
+  output=$1
+  url=$2
+  token=$(github_token)
+  if [ -n "${token}" ]; then
+    curl --fail --silent --show-error --location --retry 3 --retry-delay 2 \
+         -H "Authorization: Bearer ${token}" \
+         -H "Accept: application/vnd.github+json" \
+         --output "${output}" "${url}"
+  else
+    curl --fail --silent --show-error --location --retry 3 --retry-delay 2 \
+         --output "${output}" "${url}"
+  fi
+}
+
+curl_append() {
+  url=$1
+  token=$(github_token)
+  if [ -n "${token}" ]; then
+    curl --fail --silent --show-error --location --retry 3 --retry-delay 2 \
+         -H "Authorization: Bearer ${token}" \
+         -H "Accept: application/octet-stream" \
+         --output - "${url}"
+  else
+    curl --fail --silent --show-error --location --retry 3 --retry-delay 2 \
+         --output - "${url}"
+  fi
+}
+
+post_install() {
+  # rocknix-guest-substrate is an SM8550-only package. Other devices do
+  # not have the validated guest closure (Tier A-E spike series ran on
+  # Thor/SM8550) and should not include this package.
+  if [ "${DEVICE}" != "SM8550" ]; then
+    echo "rocknix-guest-substrate: SM8550-only (got DEVICE=${DEVICE})" >&2
+    exit 1
+  fi
+
+  substrate_lib="${INSTALL}/usr/lib/rocknix-guest-substrate"
+
+  mkdir -p ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/nix-on-rock-paths ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/nix-on-rock-migrate ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-root-ensure ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-prep ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-promote ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-start ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-recovery-toggle ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-soak ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-udev-stage ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-wifi-unblock ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-generation-import ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-generation-switch ${INSTALL}/usr/bin
+  cp ${PKG_DIR}/scripts/rocknix-guest-activation-audit ${INSTALL}/usr/bin
+  chmod 0755 \
+    ${INSTALL}/usr/bin/nix-on-rock-paths \
+    ${INSTALL}/usr/bin/nix-on-rock-migrate \
+    ${INSTALL}/usr/bin/rocknix-guest-root-ensure \
+    ${INSTALL}/usr/bin/rocknix-guest-prep \
+    ${INSTALL}/usr/bin/rocknix-guest-promote \
+    ${INSTALL}/usr/bin/rocknix-guest-start \
+    ${INSTALL}/usr/bin/rocknix-recovery-toggle \
+    ${INSTALL}/usr/bin/rocknix-guest-soak \
+    ${INSTALL}/usr/bin/rocknix-guest-udev-stage \
+    ${INSTALL}/usr/bin/rocknix-guest-wifi-unblock \
+    ${INSTALL}/usr/bin/rocknix-guest-generation-import \
+    ${INSTALL}/usr/bin/rocknix-guest-generation-switch \
+    ${INSTALL}/usr/bin/rocknix-guest-activation-audit
+
+  # Safety-net release: the guest owns InputPlumber, so mask the old host
+  # unit while leaving its package files installed for SSH rollback.
+  mkdir -p ${INSTALL}/etc/systemd/system
+  ln -sf /dev/null ${INSTALL}/etc/systemd/system/inputplumber.service
+
+  # ROCKNIX ships /usr from squashfs, so rollback artifacts must be staged in
+  # writable storage ahead of time. Operators enable these files over SSH if the
+  # guest-owned udev cutover needs to be backed out without a reflash.
+  mkdir -p \
+    ${INSTALL}/storage/.config/system.d/rocknix-guest.service.d \
+    ${INSTALL}/storage/.cache
+  cat > ${INSTALL}/storage/.config/system.d/rocknix-guest.service.d/00-restore-udev-stage.conf.disabled <<'EOF'
+[Service]
+ExecStartPre=/usr/bin/rocknix-guest-udev-stage
+EOF
+  awk '
+    { print }
+    $0 == "emit_arg \"--bind=/dev/uinput\"" {
+      print "emit_arg \"--bind-ro=/run/.guest-udev:/run/udev\""
+    }
+  ' ${PKG_DIR}/scripts/rocknix-guest-start > ${INSTALL}/storage/.cache/rocknix-guest-start-with-stage-bind
+  chmod 0755 ${INSTALL}/storage/.cache/rocknix-guest-start-with-stage-bind
+
+  mkdir -p "${substrate_lib}/tests"
+  cp ${PKG_DIR}/scripts/nix-on-rock-paths "${substrate_lib}/nix-on-rock-paths"
+  cp ${PKG_DIR}/tests/guest-substrate-runtime-smoke.sh "${substrate_lib}/tests"
+  chmod 0755 "${substrate_lib}/tests/guest-substrate-runtime-smoke.sh"
+
+  # Fetch the pinned Nix-on-Rocks product source and stage its guest/ subtree
+  # under /usr/lib/rocknix-guest-substrate/guest/. Cached under ${SOURCES}/ so
+  # repeat builds (and the fast-iter image-only workflow) hit the cache instead
+  # of GitHub. SHA256 verification is mandatory.
+  guest_tarball="${SOURCES}/nix-on-rocks/${PKG_NIX_GUEST_AUTHORITY_NAME}-${PKG_NIX_GUEST_REV}.tar.gz"
+  if [ ! -f "${guest_tarball}" ]; then
+    mkdir -p "$(dirname "${guest_tarball}")"
+    echo "rocknix-guest-substrate: fetching ${PKG_NIX_GUEST_AUTHORITY_REPO} product source ${PKG_NIX_GUEST_REV}"
+    curl_fetch "${guest_tarball}.tmp" "${PKG_NIX_GUEST_URL}"
+    actual_sha="$(sha256sum "${guest_tarball}.tmp" | awk '{print $1}')"
+    if [ "${actual_sha}" != "${PKG_NIX_GUEST_SHA256}" ]; then
+      echo "rocknix-guest-substrate: product source tarball SHA256 mismatch" >&2
+      echo "  expected: ${PKG_NIX_GUEST_SHA256}" >&2
+      echo "  actual:   ${actual_sha}" >&2
+      rm -f "${guest_tarball}.tmp"
+      exit 1
+    fi
+    mv "${guest_tarball}.tmp" "${guest_tarball}"
+  fi
+
+  actual_sha="$(sha256sum "${guest_tarball}" | awk '{print $1}')"
+  if [ "${actual_sha}" != "${PKG_NIX_GUEST_SHA256}" ]; then
+    echo "rocknix-guest-substrate: cached product source tarball SHA256 mismatch" >&2
+    echo "  expected: ${PKG_NIX_GUEST_SHA256}" >&2
+    echo "  actual:   ${actual_sha}" >&2
+    exit 1
+  fi
+
+  guest_extract="${PKG_BUILD}/.nix-on-rocks"
+  rm -rf "${guest_extract}"
+  mkdir -p "${guest_extract}"
+  tar -xzf "${guest_tarball}" -C "${guest_extract}" --strip-components=1
+  guest_source="${guest_extract}/${PKG_NIX_GUEST_SOURCE_SUBDIR}"
+  [ -f "${guest_source}/flake.nix" ] || { echo "rocknix-guest-substrate: fetched product tree lacks ${PKG_NIX_GUEST_SOURCE_SUBDIR}/flake.nix" >&2; exit 1; }
+
+  mkdir -p "${substrate_lib}/guest"
+  cp -PR "${guest_source}/." "${substrate_lib}/guest/"
+  printf '%s\n' "${PKG_NIX_GUEST_REV}" > "${substrate_lib}/guest-revision"
+  printf '%s\n' "${PKG_NIX_GUEST_REV}" > "${substrate_lib}/guest/.rocknix-guest-revision"
+
+  if { [ -z "${PKG_NIX_GUEST_ROOTFS_SEED_URL}" ] && [ -z "${PKG_NIX_GUEST_ROOTFS_SEED_URLS}" ]; } || \
+     [ "${PKG_NIX_GUEST_ROOTFS_SEED_SHA256}" = "REPLACE_WITH_BOOTABLE_ROOTFS_SEED_SHA256" ]; then
+    echo "rocknix-guest-substrate: bootable guest rootfs seed URL/SHA256 are not configured" >&2
+    echo "  Build and publish the Korri korri-rocknix-rootfs-* artifact for ${PKG_NIX_GUEST_ROOTFS_SEED_REV}, then set:" >&2
+    echo "  PKG_NIX_GUEST_ROOTFS_SEED_URL or PKG_NIX_GUEST_ROOTFS_SEED_URLS, plus PKG_NIX_GUEST_ROOTFS_SEED_SHA256" >&2
+    exit 1
+  fi
+
+  seed_tarball="${SOURCES}/nix-on-rocks/${PKG_NIX_GUEST_ROOTFS_SEED_ARCHIVE}"
+  if [ ! -f "${seed_tarball}" ]; then
+    mkdir -p "$(dirname "${seed_tarball}")"
+    echo "rocknix-guest-substrate: fetching bootable guest rootfs seed ${PKG_NIX_GUEST_ROOTFS_SEED_REV}"
+    if [ -n "${PKG_NIX_GUEST_ROOTFS_SEED_URLS}" ]; then
+      rm -f "${seed_tarball}.tmp"
+      : > "${seed_tarball}.tmp"
+      for seed_url in ${PKG_NIX_GUEST_ROOTFS_SEED_URLS}; do
+        curl_append "${seed_url}" >> "${seed_tarball}.tmp"
+      done
+    else
+      curl_fetch "${seed_tarball}.tmp" "${PKG_NIX_GUEST_ROOTFS_SEED_URL}"
+    fi
+    actual_seed_sha="$(sha256sum "${seed_tarball}.tmp" | awk '{print $1}')"
+    if [ "${actual_seed_sha}" != "${PKG_NIX_GUEST_ROOTFS_SEED_SHA256}" ]; then
+      echo "rocknix-guest-substrate: bootable guest rootfs seed SHA256 mismatch" >&2
+      echo "  expected: ${PKG_NIX_GUEST_ROOTFS_SEED_SHA256}" >&2
+      echo "  actual:   ${actual_seed_sha}" >&2
+      rm -f "${seed_tarball}.tmp"
+      exit 1
+    fi
+    mv "${seed_tarball}.tmp" "${seed_tarball}"
+  fi
+
+  actual_seed_sha="$(sha256sum "${seed_tarball}" | awk '{print $1}')"
+  if [ "${actual_seed_sha}" != "${PKG_NIX_GUEST_ROOTFS_SEED_SHA256}" ]; then
+    echo "rocknix-guest-substrate: cached bootable guest rootfs seed SHA256 mismatch" >&2
+    echo "  expected: ${PKG_NIX_GUEST_ROOTFS_SEED_SHA256}" >&2
+    echo "  actual:   ${actual_seed_sha}" >&2
+    exit 1
+  fi
+
+  seed_size="$(stat -c %s "${seed_tarball}")"
+  mkdir -p "${substrate_lib}"
+  {
+    printf 'seed_manifest_version=%s\n' '1'
+    printf 'seed_device=%s\n' "${PKG_NIX_GUEST_ROOTFS_SEED_DEVICE}"
+    printf 'seed_compatible=%s\n' "${PKG_NIX_GUEST_ROOTFS_SEED_COMPATIBLE}"
+    printf 'seed_revision=%s\n' "${PKG_NIX_GUEST_ROOTFS_SEED_REV}"
+    printf 'seed_archive=%s\n' "${PKG_NIX_GUEST_ROOTFS_SEED_ARCHIVE}"
+    printf 'seed_sha256=%s\n' "${PKG_NIX_GUEST_ROOTFS_SEED_SHA256}"
+    printf 'seed_size=%s\n' "${seed_size}"
+    printf 'seed_source_urls=%s\n' "${PKG_NIX_GUEST_ROOTFS_SEED_URL:-${PKG_NIX_GUEST_ROOTFS_SEED_URLS}}"
+  } > "${substrate_lib}/guest-rootfs-seed.manifest"
+
+  # Keep the multi-GB rootfs seed outside ${INSTALL}/SYSTEM. scripts/image
+  # picks this staging directory up for SM8550 update tarballs under target/seed/.
+  seed_release_dir="${BUILD}/rocknix-guest-rootfs-seed"
+  rm -rf "${seed_release_dir}"
+  mkdir -p "${seed_release_dir}"
+  cp "${seed_tarball}" "${seed_release_dir}/${PKG_NIX_GUEST_ROOTFS_SEED_ARCHIVE}"
+
+  # Contract docs are owned by Nix-on-Rocks under docs/contracts/.
+  # Staged into ${PKG_DIR}/contract-docs/ by scripts/apply-rocknix-patches.
+  mkdir -p "${substrate_lib}/docs"
+  cp "${PKG_DIR}/contract-docs/layer14-main-space-contract.md" "${substrate_lib}/docs/"
+  cp "${PKG_DIR}/contract-docs/layer14-soak-checklist.md" "${substrate_lib}/docs/"
+
+  # Main-space wiring. SM8550 always boots the NixOS guest by default;
+  # ROCKNIX remains the recovery plane via rocknix-recovery-toggle.
+  enable_service rocknix-main-space.target
+  enable_service rocknix-guest-root-ensure.service
+  enable_service rocknix-guest.service
+  enable_service rocknix-guest-wifi-ready.service
+  enable_service rocknix-guest-promote.service
+  enable_service rocknix-recovery-toggle.service
+
+  # Ship the recovery readme to /flash/. Staged into
+  # ${PKG_DIR}/contract-docs/ by scripts/apply-rocknix-patches so a
+  # teardown / SD-card reader on another machine can read it without
+  # booting Thor.
+  mkdir -p ${INSTALL}/flash
+  cp "${PKG_DIR}/contract-docs/HOW-TO-FALL-BACK.md" ${INSTALL}/flash/HOW-TO-FALL-BACK.md
+  if [ "${SM8550_MINIMAL_HOST:-no}" = "yes" ]; then
+    cat >> ${INSTALL}/flash/HOW-TO-FALL-BACK.md <<'EOF'
+
+## SM8550 minimal-host recovery note
+
+This image is built with `SM8550_MINIMAL_HOST=yes`. Recovery mode is
+SSH-first: `/flash/rocknix.no-nspawn` or `rocknix.safe=1` routes the next
+boot to `multi-user.target` so host SSH, storage, and `/storage/.update/`
+remain available without starting the legacy ROCKNIX UI stack. Remove the
+flag file and reboot to return to the NixOS guest main-space target.
+EOF
+  fi
+
+}
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/nix-on-rock-migrate b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/nix-on-rock-migrate
new file mode 100755
index 0000000000..7771c1e3c9
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/nix-on-rock-migrate
@@ -0,0 +1,175 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# Idempotently migrate the legacy SM8550 guest storage layout into the visible
+# /storage/nix-on-rock contract before root-ensure can seed a fresh root.
+
+set -eu
+
+PATH="${ROCKNIX_GUEST_HOST_PATH:-/usr/bin:/usr/sbin:/bin:/sbin}"
+
+source_paths() {
+  if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+    . "${ROCKNIX_GUEST_PATHS_FILE}"
+    return 0
+  fi
+  if [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+    . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+    return 0
+  fi
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  if [ -r "${script_dir}/nix-on-rock-paths" ]; then
+    . "${script_dir}/nix-on-rock-paths"
+    return 0
+  fi
+  echo "nix-on-rock-migrate: FAIL: cannot locate nix-on-rock-paths" >&2
+  exit 1
+}
+
+source_paths
+
+LOCK_FILE="${ROCKNIX_GUEST_ROOT_LOCK:-/run/lock/rocknix-guest-root.lock}"
+GUEST_SERVICE="${ROCKNIX_GUEST_SERVICE:-rocknix-guest.service}"
+LOG_TAG="nix-on-rock-migrate"
+LAYOUT_VERSION="1"
+
+log() { printf '%s: %s\n' "${LOG_TAG}" "$*"; }
+fail() { log "FAIL: $*" >&2; exit 1; }
+
+is_symlink_path() { [ -L "$1" ]; }
+
+is_empty_dir() {
+  [ -d "$1" ] || return 1
+  [ -z "$(find "$1" -mindepth 1 -maxdepth 1 2>/dev/null | sed -n '1p')" ]
+}
+
+basic_root_valid() {
+  root="$1"
+  [ -d "${root}/nix" ] || return 1
+  [ -d "${root}/etc" ] || return 1
+  [ -d "${root}/sbin" ] || return 1
+}
+
+acquire_lock() {
+  lock_dir="${LOCK_FILE}.d"
+  mkdir -p "$(dirname "${LOCK_FILE}")"
+  if ! mkdir "${lock_dir}" 2>/dev/null; then
+    fail "guest root mutation lock is held: ${LOCK_FILE}"
+  fi
+  trap 'rmdir "${lock_dir}" 2>/dev/null || true' EXIT INT TERM
+}
+
+refuse_if_guest_active() {
+  if command -v systemctl >/dev/null 2>&1; then
+    if systemctl is-active --quiet "${GUEST_SERVICE}" 2>/dev/null; then
+      fail "${GUEST_SERVICE} is active; refusing storage layout migration"
+    fi
+  fi
+}
+
+ensure_contract_dirs() {
+  storage_root=$(dirname "${NIX_ON_ROCK_ROOT}")
+  for path in "${storage_root}" "${NIX_ON_ROCK_ROOT}" "${NIX_ON_ROCK_ROOTFS_DIR}" "${NIX_ON_ROCK_IMAGES_DIR}" "${NIX_ON_ROCK_SEED_DIR}" "${NIX_ON_ROCK_REQUESTS_DIR}" "${NIX_ON_ROCK_STATE_DIR}" "${NIX_ON_ROCK_STAGING_DIR}" "${NIX_ON_ROCK_GUEST_EXCHANGE_DIR}"; do
+    if [ -e "${path}" ] && is_symlink_path "${path}" ]; then
+      fail "contract path is a symlink: ${path}"
+    fi
+    mkdir -p "${path}"
+    chmod 0755 "${path}" 2>/dev/null || true
+  done
+}
+
+move_if_present() {
+  src="$1"
+  dst="$2"
+  label="$3"
+  [ -e "${src}" ] || return 0
+  if [ -e "${dst}" ]; then
+    fail "cannot migrate ${label}: both legacy and new paths exist (${src}, ${dst})"
+  fi
+  mkdir -p "$(dirname "${dst}")"
+  log "migrating ${label}: ${src} -> ${dst}"
+  mv "${src}" "${dst}" || fail "failed to migrate ${label}: ${src} -> ${dst}"
+}
+
+move_contents_if_dir_present() {
+  src_dir="$1"
+  dst_dir="$2"
+  label="$3"
+  [ -d "${src_dir}" ] || return 0
+  mkdir -p "${dst_dir}"
+  for entry in "${src_dir}"/* "${src_dir}"/.[!.]* "${src_dir}"/..?*; do
+    [ -e "${entry}" ] || continue
+    name=$(basename "${entry}")
+    dst="${dst_dir}/${name}"
+    if [ -e "${dst}" ]; then
+      fail "cannot migrate ${label} entry ${name}: destination exists at ${dst}"
+    fi
+    log "migrating ${label} entry: ${entry} -> ${dst}"
+    mv "${entry}" "${dst}" || fail "failed to migrate ${label} entry ${entry}"
+  done
+  rmdir "${src_dir}" 2>/dev/null || true
+}
+
+install_legacy_area_alias() {
+  [ "${NIX_ON_ROCK_LEGACY_AREA}" = "${NIX_ON_ROCK_GUEST_EXCHANGE_DIR}" ] && return 0
+  if [ -e "${NIX_ON_ROCK_LEGACY_AREA}" ]; then
+    if [ -L "${NIX_ON_ROCK_LEGACY_AREA}" ]; then
+      return 0
+    fi
+    if is_empty_dir "${NIX_ON_ROCK_LEGACY_AREA}"; then
+      rmdir "${NIX_ON_ROCK_LEGACY_AREA}" || fail "failed to remove empty legacy seam: ${NIX_ON_ROCK_LEGACY_AREA}"
+    else
+      fail "legacy seam still has unmigrated content: ${NIX_ON_ROCK_LEGACY_AREA}"
+    fi
+  fi
+  mkdir -p "$(dirname "${NIX_ON_ROCK_LEGACY_AREA}")"
+  ln -s "${NIX_ON_ROCK_GUEST_EXCHANGE_DIR}" "${NIX_ON_ROCK_LEGACY_AREA}" 2>/dev/null || true
+}
+
+migrate_roots() {
+  if [ -d "${NIX_ON_ROCK_LEGACY_ROOT}" ] && [ ! -L "${NIX_ON_ROCK_LEGACY_ROOT}" ]; then
+    basic_root_valid "${NIX_ON_ROCK_LEGACY_ROOT}" || fail "legacy guest root is not valid; refusing migration: ${NIX_ON_ROCK_LEGACY_ROOT}"
+    move_if_present "${NIX_ON_ROCK_LEGACY_ROOT}" "${NIX_ON_ROCK_CURRENT_ROOT}" "active guest root"
+  fi
+  if [ -d "${NIX_ON_ROCK_LEGACY_PREVIOUS_ROOT}" ] && [ ! -L "${NIX_ON_ROCK_LEGACY_PREVIOUS_ROOT}" ]; then
+    move_if_present "${NIX_ON_ROCK_LEGACY_PREVIOUS_ROOT}" "${NIX_ON_ROCK_PREVIOUS_ROOT}" "previous guest root"
+  fi
+}
+
+migrate_area() {
+  legacy="${NIX_ON_ROCK_LEGACY_AREA}"
+  [ -e "${legacy}" ] || return 0
+  [ ! -L "${legacy}" ] || return 0
+  [ -d "${legacy}" ] || fail "legacy seam is not a directory: ${legacy}"
+
+  move_contents_if_dir_present "${legacy}/seed" "${NIX_ON_ROCK_SEED_DIR}" "seed images"
+  move_if_present "${legacy}/rocknix-guest-manual-generation-hold" "${NIX_ON_ROCK_MANUAL_HOLD_FILE}" "manual generation hold"
+  move_if_present "${legacy}/rocknix-guest-generation-switch-a" "${NIX_ON_ROCK_SWITCH_STATE_FILE}" "generation switch state"
+  move_if_present "${legacy}/rocknix-guest-generation-import-candidate" "${NIX_ON_ROCK_IMPORT_PROVENANCE_FILE}" "generation import candidate"
+  move_if_present "${legacy}/rocknix-guest-promote-system-path" "${NIX_ON_ROCK_PROMOTE_SYSTEM_PATH_FILE}" "promote system path"
+  move_if_present "${legacy}/rocknix-nix-guest-packaged" "${NIX_ON_ROCK_STAGED_SOURCE}" "packaged guest source"
+  move_if_present "${legacy}/rocknix-nix-guest-packaged.previous" "${NIX_ON_ROCK_STAGED_SOURCE}.previous" "previous packaged guest source"
+
+  install_legacy_area_alias
+}
+
+main() {
+  acquire_lock
+  refuse_if_guest_active
+  ensure_contract_dirs
+
+  if [ -e "${NIX_ON_ROCK_MIGRATION_IN_PROGRESS}" ]; then
+    fail "layout migration was interrupted; inspect ${NIX_ON_ROCK_MIGRATION_IN_PROGRESS} before continuing"
+  fi
+
+  : > "${NIX_ON_ROCK_MIGRATION_IN_PROGRESS}"
+  migrate_roots
+  migrate_area
+  printf '%s\n' "${LAYOUT_VERSION}" > "${NIX_ON_ROCK_LAYOUT_VERSION_FILE}"
+  rm -f "${NIX_ON_ROCK_MIGRATION_IN_PROGRESS}"
+  sync "${NIX_ON_ROCK_ROOT}" 2>/dev/null || sync
+  log "layout version ${LAYOUT_VERSION} ready at ${NIX_ON_ROCK_ROOT}"
+}
+
+main "$@"
