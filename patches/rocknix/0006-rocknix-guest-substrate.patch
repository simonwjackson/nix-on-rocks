new file mode 100755
index 0000000000..1029603f74
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-activation-audit
@@ -0,0 +1,200 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# Read-only Stage 10 generation-state audit for the SM8550 guest substrate.
+# This script reports the selected profile, running guest /run/current-system,
+# init symlinks, promotion markers, manual-generation
+# hold state, and optional proof marker. It never repairs state.
+
+set -eu
+
+PATH="${ROCKNIX_GUEST_HOST_PATH:-/usr/bin:/usr/sbin:/bin:/sbin}"
+
+if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+  . "${ROCKNIX_GUEST_PATHS_FILE}"
+elif [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+  . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+else
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  [ -r "${script_dir}/nix-on-rock-paths" ] && . "${script_dir}/nix-on-rock-paths"
+fi
+
+NIX_ON_ROCK_CURRENT_ROOT="${NIX_ON_ROCK_CURRENT_ROOT:-/storage/nix-on-rock/rootfs/current}"
+NIX_ON_ROCK_MANUAL_HOLD_FILE="${NIX_ON_ROCK_MANUAL_HOLD_FILE:-/storage/nix-on-rock/requests/manual-generation-hold}"
+NIX_ON_ROCK_IMPORT_PROVENANCE_FILE="${NIX_ON_ROCK_IMPORT_PROVENANCE_FILE:-/storage/nix-on-rock/staging/generation-import-candidate}"
+NIX_ON_ROCK_SEED_DIR="${NIX_ON_ROCK_SEED_DIR:-/storage/nix-on-rock/images/seeds}"
+NIX_ON_ROCK_LAYOUT_VERSION_FILE="${NIX_ON_ROCK_LAYOUT_VERSION_FILE:-/storage/nix-on-rock/state/layout-version}"
+
+GUEST_ROOT="${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}"
+GUEST_SERVICE="${ROCKNIX_GUEST_SERVICE:-rocknix-guest.service}"
+SELECTED_PROFILE_GUEST="${ROCKNIX_GUEST_SYSTEM_PROFILE:-/nix/var/nix/profiles/per-user/root/rocknix-guest-system}"
+APPLIED_REV_FILE="${ROCKNIX_GUEST_APPLIED_REV_FILE:-${GUEST_ROOT}/etc/rocknix-guest-revision}"
+APPLIED_SYSTEM_FILE="${ROCKNIX_GUEST_APPLIED_SYSTEM_FILE:-${GUEST_ROOT}/etc/rocknix-guest-system-path}"
+MANUAL_HOLD_FILE="${ROCKNIX_GUEST_MANUAL_HOLD_FILE:-${NIX_ON_ROCK_MANUAL_HOLD_FILE}}"
+IMPORT_PROVENANCE_FILE="${ROCKNIX_GUEST_IMPORT_PROVENANCE:-${NIX_ON_ROCK_IMPORT_PROVENANCE_FILE}}"
+SEED_MANIFEST="${ROCKNIX_GUEST_ROOTFS_SEED_MANIFEST:-/usr/lib/rocknix-guest-substrate/guest-rootfs-seed.manifest}"
+SEED_DIR="${ROCKNIX_GUEST_ROOTFS_SEED_DIR:-${NIX_ON_ROCK_SEED_DIR}}"
+SEED_COMPLETE_FILE="${ROCKNIX_GUEST_SEED_COMPLETE_FILE:-${GUEST_ROOT}/etc/rocknix-guest-root-seed-complete}"
+RESEED_FLAG="${ROCKNIX_GUEST_RESEED_FLAG:-/flash/rocknix.reseed-guest}"
+PROOF_MARKER_REL="${ROCKNIX_GUEST_PROOF_MARKER_REL:-etc/rocknix-stage10-proof-marker}"
+ALLOW_TRANSITION="${ROCKNIX_GUEST_AUDIT_ALLOW_TRANSITION:-0}"
+QUIET=0
+LOG_TAG="rocknix-guest-activation-audit"
+
+while [ $# -gt 0 ]; do
+  case "$1" in
+    --quiet) QUIET=1; shift ;;
+    --allow-transition) ALLOW_TRANSITION=1; shift ;;
+    -h|--help)
+      sed -n '1,40p' "$0"
+      exit 0
+      ;;
+    *)
+      printf '%s: unknown arg: %s\n' "${LOG_TAG}" "$1" >&2
+      exit 2
+      ;;
+  esac
+done
+
+log() {
+  [ "${QUIET}" = "1" ] && return 0
+  printf '%s: %s\n' "${LOG_TAG}" "$*"
+}
+
+warn() {
+  printf '%s: WARNING: %s\n' "${LOG_TAG}" "$*" >&2
+}
+
+fail() {
+  printf '%s: FAIL: %s\n' "${LOG_TAG}" "$*" >&2
+  exit 1
+}
+
+read_first_line() {
+  file="$1"
+  if [ -r "${file}" ]; then
+    sed -n '1p' "${file}" | tr -d '[:space:]'
+  fi
+}
+
+read_key_value() {
+  file="$1"
+  key="$2"
+  if [ -r "${file}" ]; then
+    sed -n "s/^${key}=//p" "${file}" | sed -n '1p'
+  fi
+}
+
+profile_host_path() {
+  case "$1" in
+    /nix/*) printf '%s%s\n' "${GUEST_ROOT}" "$1" ;;
+    *) fail "profile path must be guest-absolute under /nix: $1" ;;
+  esac
+}
+
+resolve_guest_profile() {
+  profile_guest_path="$1"
+  profile_path="$(profile_host_path "${profile_guest_path}")"
+  [ -L "${profile_path}" ] || return 1
+
+  target="$(readlink "${profile_path}" 2>/dev/null || true)"
+  case "${target}" in
+    /nix/*) resolved="${target}" ;;
+    '') return 1 ;;
+    *) resolved="$(readlink "$(dirname "${profile_path}")/${target}" 2>/dev/null || true)" ;;
+  esac
+
+  case "${resolved}" in /nix/*) : ;; *) return 1 ;; esac
+  [ -x "${GUEST_ROOT}${resolved}/init" ] || return 1
+  printf '%s\n' "${resolved}"
+}
+
+running_guest_system() {
+  outer_pid="$(systemctl show -p MainPID --value "${GUEST_SERVICE}" 2>/dev/null || true)"
+  case "${outer_pid}" in ''|0) return 1 ;; esac
+  inner_pid="$(pgrep -P "${outer_pid}" 2>/dev/null | head -1 || true)"
+  [ -n "${inner_pid}" ] || return 1
+  readlink "/proc/${inner_pid}/root/run/current-system" 2>/dev/null || true
+}
+
+running_guest_has_file() {
+  guest_path="$1"
+  outer_pid="$(systemctl show -p MainPID --value "${GUEST_SERVICE}" 2>/dev/null || true)"
+  case "${outer_pid}" in ''|0) return 1 ;; esac
+  file_check_inner_pid="$(pgrep -P "${outer_pid}" 2>/dev/null | head -1 || true)"
+  [ -n "${file_check_inner_pid}" ] || return 1
+  nsenter -t "${file_check_inner_pid}" -m -u -i -n -p sh -c "[ -f '${guest_path}' ]" 2>/dev/null
+}
+
+[ -d "${GUEST_ROOT}" ] || fail "guest root missing: ${GUEST_ROOT}"
+[ -d "${GUEST_ROOT}/nix" ] || fail "guest rootfs /nix missing: ${GUEST_ROOT}/nix"
+
+selected_system="$(resolve_guest_profile "${SELECTED_PROFILE_GUEST}" || true)"
+running_system="$(running_guest_system || true)"
+init_link="$(readlink "${GUEST_ROOT}/init" 2>/dev/null || true)"
+sbin_init_link="$(readlink "${GUEST_ROOT}/sbin/init" 2>/dev/null || true)"
+applied_rev="$(read_first_line "${APPLIED_REV_FILE}")"
+applied_system="$(read_first_line "${APPLIED_SYSTEM_FILE}")"
+hold_state="absent"
+[ -e "${MANUAL_HOLD_FILE}" ] && hold_state="present"
+import_candidate=""
+if [ -r "${IMPORT_PROVENANCE_FILE}" ]; then
+  import_candidate="$(sed -n 's/^system=//p' "${IMPORT_PROVENANCE_FILE}" | head -1 | tr -d '[:space:]')"
+fi
+seed_expected_revision="$(read_key_value "${SEED_MANIFEST}" seed_revision)"
+seed_expected_archive="$(read_key_value "${SEED_MANIFEST}" seed_archive)"
+seed_expected_sha="$(read_key_value "${SEED_MANIFEST}" seed_sha256)"
+seed_complete_revision="$(read_key_value "${SEED_COMPLETE_FILE}" seed_revision)"
+seed_staged_state="unknown"
+if [ -n "${seed_expected_archive}" ]; then
+  seed_staged_path="${SEED_DIR}/${seed_expected_archive}"
+  if [ -f "${seed_staged_path}" ]; then
+    seed_staged_state="present"
+    if [ -n "${seed_expected_sha}" ]; then
+      seed_actual_sha="$(sha256sum "${seed_staged_path}" 2>/dev/null | awk '{print $1}')"
+      [ "${seed_actual_sha}" = "${seed_expected_sha}" ] || seed_staged_state="sha-mismatch"
+    fi
+  else
+    seed_staged_state="missing"
+  fi
+fi
+reseed_state="absent"
+[ -e "${RESEED_FLAG}" ] && reseed_state="present"
+
+log "selected=${selected_system:-none}"
+log "running=${running_system:-none}"
+log "init=${init_link:-none}"
+log "sbin_init=${sbin_init_link:-none}"
+log "applied_rev=${applied_rev:-none}"
+log "applied_system=${applied_system:-none}"
+log "manual_generation_hold=${hold_state}"
+log "import_candidate=${import_candidate:-none}"
+log "seed_expected_revision=${seed_expected_revision:-none}"
+log "seed_complete_revision=${seed_complete_revision:-none}"
+log "seed_staged=${seed_staged_state}"
+layout_version="missing"
+[ -r "${NIX_ON_ROCK_LAYOUT_VERSION_FILE}" ] && layout_version="$(sed -n '1p' "${NIX_ON_ROCK_LAYOUT_VERSION_FILE}" | tr -d '[:space:]')"
+log "reseed_flag=${reseed_state}"
+log "nix_on_rock_layout=${layout_version}"
+
+[ -n "${selected_system}" ] || fail "selected guest profile is missing or invalid"
+expected_init="${selected_system}/init"
+[ "${init_link}" = "${expected_init}" ] || fail "guest /init drifted: ${init_link:-none} expected=${expected_init}"
+[ "${sbin_init_link}" = "${expected_init}" ] || fail "guest /sbin/init drifted: ${sbin_init_link:-none} expected=${expected_init}"
+
+if [ -n "${running_system}" ] && [ "${running_system}" != "${selected_system}" ]; then
+  if [ "${ALLOW_TRANSITION}" = "1" ]; then
+    warn "running generation differs during allowed transition: running=${running_system} selected=${selected_system}"
+  else
+    fail "running generation drifted: running=${running_system} selected=${selected_system}"
+  fi
+fi
+
+if [ -n "${running_system}" ] && running_guest_has_file "${running_system}/${PROOF_MARKER_REL}"; then
+  log "proof_marker=${running_system}/${PROOF_MARKER_REL}"
+elif [ -n "${running_system}" ] && [ -n "${import_candidate}" ] && [ "${running_system}" = "${import_candidate}" ]; then
+  fail "running imported candidate is missing proof marker: ${running_system}/${PROOF_MARKER_REL}"
+fi
+
+log "audit complete"
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-generation-import b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-generation-import
new file mode 100755
index 0000000000..eae549ce48
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-generation-import
@@ -0,0 +1,121 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# Import and verify an off-device-built SM8550 guest generation for the Stage 10
+# A->B->A proof. This helper deliberately requires a healthy running guest A so
+# import and verification happen in the same namespace that owns guest Nix.
+
+set -eu
+
+PATH="${ROCKNIX_GUEST_HOST_PATH:-/usr/bin:/usr/sbin:/bin:/sbin}"
+
+if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+  . "${ROCKNIX_GUEST_PATHS_FILE}"
+elif [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+  . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+else
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  [ -r "${script_dir}/nix-on-rock-paths" ] && . "${script_dir}/nix-on-rock-paths"
+fi
+
+NIX_ON_ROCK_CURRENT_ROOT="${NIX_ON_ROCK_CURRENT_ROOT:-/storage/nix-on-rock/rootfs/current}"
+NIX_ON_ROCK_IMPORT_PROVENANCE_FILE="${NIX_ON_ROCK_IMPORT_PROVENANCE_FILE:-/storage/nix-on-rock/staging/generation-import-candidate}"
+
+GUEST_ROOT="${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}"
+GUEST_SERVICE="${ROCKNIX_GUEST_SERVICE:-rocknix-guest.service}"
+SELECTED_PROFILE_GUEST="${ROCKNIX_GUEST_SYSTEM_PROFILE:-/nix/var/nix/profiles/per-user/root/rocknix-guest-system}"
+IMPORT_PROVENANCE_FILE="${ROCKNIX_GUEST_IMPORT_PROVENANCE:-${NIX_ON_ROCK_IMPORT_PROVENANCE_FILE}}"
+PROOF_MARKER_REL="${ROCKNIX_GUEST_PROOF_MARKER_REL:-etc/rocknix-stage10-proof-marker}"
+TARGET_ID="thor"
+NAR_FILE=""
+SYSTEM_PATH=""
+SOURCE_REF="unknown"
+LOG_TAG="rocknix-guest-generation-import"
+
+usage() {
+  cat <<EOF
+Usage: ${LOG_TAG} --system /nix/store/<toplevel> [--nar /storage/nix-on-rock/staging/closure.nar] [--source REF]
+
+Imports/verifies an SM8550 guest generation while the current guest generation A
+is running. Build B off-device from the product authority flake, e.g.:
+  nix build github:simonwjackson/korri/<rev>#packages.aarch64-linux.korri-rocknix-kiosk-system-thor
+  nix build github:simonwjackson/korri/<rev>#packages.aarch64-linux.korri-rocknix-kiosk-system-odin2portal
+EOF
+}
+
+log() { printf '%s: %s\n' "${LOG_TAG}" "$*"; }
+fail() { log "FAIL: $*"; exit 1; }
+
+while [ $# -gt 0 ]; do
+  case "$1" in
+    --system) SYSTEM_PATH="$2"; shift 2 ;;
+    --nar) NAR_FILE="$2"; shift 2 ;;
+    --source) SOURCE_REF="$2"; shift 2 ;;
+    --target) TARGET_ID="$2"; shift 2 ;;
+    -h|--help) usage; exit 0 ;;
+    *) fail "unknown arg: $1" ;;
+  esac
+done
+
+[ -n "${SYSTEM_PATH}" ] || fail "--system is required"
+case "${SYSTEM_PATH}" in /nix/store/*) : ;; *) fail "system path must be guest-absolute under /nix/store: ${SYSTEM_PATH}" ;; esac
+case "${TARGET_ID}" in
+  thor|odin2portal) : ;;
+  *) fail "Stage 10 import proof target must be thor or odin2portal (got target=${TARGET_ID})" ;;
+esac
+[ -d "${GUEST_ROOT}" ] || fail "guest rootfs missing: ${GUEST_ROOT}"
+[ -d "${GUEST_ROOT}/nix" ] || fail "guest /nix missing under ${GUEST_ROOT}"
+
+resolve_profile() {
+  profile_guest_path="$1"
+  profile_path="${GUEST_ROOT}${profile_guest_path}"
+  [ -L "${profile_path}" ] || return 1
+  target="$(readlink "${profile_path}" 2>/dev/null || true)"
+  case "${target}" in
+    /nix/*) resolved="${target}" ;;
+    '') return 1 ;;
+    *) resolved="$(readlink "$(dirname "${profile_path}")/${target}" 2>/dev/null || true)" ;;
+  esac
+  case "${resolved}" in /nix/*) : ;; *) return 1 ;; esac
+  [ -x "${GUEST_ROOT}${resolved}/init" ] || return 1
+  printf '%s\n' "${resolved}"
+}
+
+ensure_guest_namespace() {
+  outer_pid="$(systemctl show -p MainPID --value "${GUEST_SERVICE}" 2>/dev/null || true)"
+  case "${outer_pid}" in ''|0) fail "${GUEST_SERVICE} is not running; live generation A is required for import" ;; esac
+  inner_pid="$(pgrep -P "${outer_pid}" | head -1 || true)"
+  [ -n "${inner_pid}" ] || fail "could not find guest payload PID under ${outer_pid}"
+}
+
+selected="$(resolve_profile "${SELECTED_PROFILE_GUEST}" || true)"
+[ -n "${selected}" ] || fail "selected profile is missing before import"
+
+ensure_guest_namespace
+running="$(readlink "/proc/${inner_pid}/root/run/current-system" 2>/dev/null || true)"
+[ -n "${running}" ] || fail "running guest /run/current-system is missing"
+[ "${running}" = "${selected}" ] || fail "healthy generation A required before import: selected=${selected} running=${running}"
+
+if [ -n "${NAR_FILE}" ]; then
+  [ -r "${NAR_FILE}" ] || fail "nar archive is not readable: ${NAR_FILE}"
+  log "importing closure archive into live guest namespace: ${NAR_FILE}"
+  nsenter -t "${inner_pid}" -m -u -i -n -p sh -c "set -eu; export PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/bin:/usr/bin; /run/current-system/sw/bin/nix-store --import < '${NAR_FILE}'"
+fi
+
+log "verifying candidate from live guest namespace: ${SYSTEM_PATH}"
+nsenter -t "${inner_pid}" -m -u -i -n -p sh -c "set -eu; export PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/bin:/usr/bin; [ -x '${SYSTEM_PATH}/init' ]; /run/current-system/sw/bin/nix-store -qR '${SYSTEM_PATH}' >/dev/null; /run/current-system/sw/bin/nix-store --verify-path '${SYSTEM_PATH}' >/dev/null; [ -f '${SYSTEM_PATH}/${PROOF_MARKER_REL}' ]"
+
+[ -x "${GUEST_ROOT}${SYSTEM_PATH}/init" ] || fail "candidate init is not visible from host guest-rootfs view: ${GUEST_ROOT}${SYSTEM_PATH}/init"
+
+mkdir -p "$(dirname "${IMPORT_PROVENANCE_FILE}")"
+{
+  printf 'system=%s\n' "${SYSTEM_PATH}"
+  printf 'target=%s\n' "${TARGET_ID}"
+  printf 'source=%s\n' "${SOURCE_REF}"
+  printf 'imported_at=%s\n' "$(date -u +%FT%TZ)"
+  printf 'verified_from=live-generation-a\n'
+  printf 'proof_marker=%s\n' "${SYSTEM_PATH}/${PROOF_MARKER_REL}"
+} > "${IMPORT_PROVENANCE_FILE}"
+
+log "candidate imported and verified: ${SYSTEM_PATH}"
