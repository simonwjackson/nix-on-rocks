diff --git a/projects/ROCKNIX/devices/RK3326/options b/projects/ROCKNIX/devices/RK3326/options
--- a/projects/ROCKNIX/devices/RK3326/options
+++ b/projects/ROCKNIX/devices/RK3326/options
@@ -80,3 +80,37 @@
 
   # Disk Swap
     SWAP_FILE_SIZE="0"
+
+  # Nix-on-Rocks R36T Max minimal-host lane. This keeps the SD-card proof
+  # close to the existing thin-host image lanes: recovery networking, SSH,
+  # boot/storage/update substrate, RK915 Wi-Fi, and no host UX/emulator stack.
+    RK3326_R36TMAX_MINIMAL_HOST="${RK3326_R36TMAX_MINIMAL_HOST:-no}"
+    if [ "${RK3326_R36TMAX_MINIMAL_HOST}" = "yes" ]; then
+      VULKAN_SUPPORT="no"
+      VULKAN="no"
+      DISPLAYSERVER="no"
+      WINDOWMANAGER="none"
+      EMULATION_DEVICE="no"
+      PIPEWIRE_SUPPORT="no"
+      BLUETOOTH_SUPPORT="no"
+      AVAHI_DAEMON="no"
+      REMOTE_SUPPORT="no"
+      JOYSTICK_SUPPORT="no"
+      MODULES_PKG="no"
+      DEBUG_PACKAGES="no"
+      NFS_SUPPORT="no"
+      SAMBA_SERVER="no"
+      SFTP_SERVER="no"
+      SIMPLE_HTTP_SERVER="no"
+      ZEROTIER_SUPPORT="no"
+      WIREGUARD_SUPPORT="no"
+      ENABLE_32BIT=no
+      NTFS3G="no"
+      EXFAT="no"
+      UDEVIL="no"
+      NANO_EDITOR="no"
+      HTOP_TOOL="no"
+      BTOP_TOOL="no"
+      ADDITIONAL_PACKAGES=""
+      ADDITIONAL_PACKAGES_32BIT=""
+    fi
