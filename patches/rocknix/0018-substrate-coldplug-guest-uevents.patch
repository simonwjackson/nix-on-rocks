diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-start b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-start
index 741b7d5c1c..5a6d7ac2c8 100755
--- a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-start
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-start
@@ -131,6 +131,23 @@ has_candidate_media_member() {
   return 1
 }
 
+emit_coldplug_uevent_binds() {
+  seen=" "
+  for uevent_path in \
+    /sys/class/drm/*/uevent \
+    /sys/class/input/input*/uevent \
+    /sys/class/input/event*/uevent
+  do
+    [ -e "${uevent_path}" ] || continue
+    case "${seen}" in
+      *" ${uevent_path} "*) continue ;;
+    esac
+    seen="${seen}${uevent_path} "
+    emit_arg "--bind=${uevent_path}"
+    log "pass writable coldplug uevent ${uevent_path}"
+  done
+}
+
 emit_backlight_brightness_binds() {
   for brightness_path in /sys/class/backlight/*/brightness; do
     [ -e "${brightness_path}" ] || continue
@@ -219,6 +236,11 @@ emit_backlight_brightness_binds
 emit_arg "--bind=/sys/class/leds"
 emit_arg "--bind=/sys/class/devfreq"
 emit_arg "--bind=/sys/devices/system/cpu/cpufreq"
+# systemd-nspawn mounts /sys read-only for the guest. Layer writable uevent
+# file binds over the DRM/input class aliases so guest udev can synthesize the
+# coldplug events logind needs for rootless DRM and uaccess ownership without
+# exposing broad sysfs mutation.
+emit_coldplug_uevent_binds
 emit_arg "--bind=${NIX_ON_ROCK_GUEST_EXCHANGE_DIR}:${NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH}"
 
 # Pass through any v4l2 codec character devices the kernel exposes
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service
index 6877919507..e8f2e9c011 100644
--- a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service
@@ -169,5 +169,12 @@ ExecStartPre=/usr/bin/rocknix-guest-prep
 # SSH rollback uses a disabled drop-in staged under /storage by package.mk.
 
+# Do not run a host ExecStartPost udev trigger for DRM after the guest has
+# started. wlroots/logind may already own KMS by then; synthetic card-level DRM
+# change events at that point can desynchronise libseat device accounting and
+# leave Sway with EACCES atomic commits. rocknix-guest-start binds only the
+# minimal uevent files up front so the guest's normal early udev coldplug can
+# classify devices before the compositor opens them.
+
 ExecStart=/usr/bin/rocknix-guest-start
 
 Restart=on-failure
