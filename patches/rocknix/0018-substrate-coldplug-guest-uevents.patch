 check_grep 'mkdir -p /dev/input/\.inputplumber/sources' "${SCRIPT_ROOT}/rocknix-guest-start" "guest start helper must create InputPlumber sources inside the /dev/input bind"
 check_grep '--bind=/dev/uinput' "${SCRIPT_ROOT}/rocknix-guest-start" "guest start helper must pass through uinput for guest InputPlumber"
+check_grep 'emit_coldplug_uevent_binds' "${SCRIPT_ROOT}/rocknix-guest-start" "guest start helper must bind writable coldplug uevent files"
+check_grep '/sys/class/drm/\*/uevent' "${SCRIPT_ROOT}/rocknix-guest-start" "guest start helper must expose DRM uevent files for guest coldplug"
+check_grep '/sys/class/input/event\*/uevent' "${SCRIPT_ROOT}/rocknix-guest-start" "guest start helper must expose input event uevent files for guest coldplug"
 check_grep 'for v_node in /dev/video' "${SCRIPT_ROOT}/rocknix-guest-start" "guest start helper must enumerate /dev/video[0-9]* at runtime for Moonlight v4l2m2m"
