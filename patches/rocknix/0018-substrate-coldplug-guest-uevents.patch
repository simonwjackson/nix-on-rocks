index 0000000000..b609da7936
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-coldplug
@@ -0,0 +1,83 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# Run targeted guest udev coldplug after the nspawn payload is alive.
+#
+# The guest owns udev/logind state, but systemd-nspawn mounts sysfs read-only by
+# default. rocknix-guest-start layers writable uevent file binds over DRM/input
+# class aliases; this helper then asks guest udev to process those events so
+# logind can attach the passed-through KMS/input devices to seat0. Keep this
+# targeted: ROCKNIX remains the host owner of sysfs, while the guest receives
+# enough synthetic coldplug to classify devices it is explicitly allowed to use.
+
+set -eu
+
+PATH=/usr/sbin:/usr/bin:/sbin:/bin
+export PATH
+
+LOG_TAG="rocknix-guest-coldplug"
+GUEST_SERVICE="${ROCKNIX_GUEST_SERVICE:-rocknix-guest.service}"
+TIMEOUT_SECONDS="${ROCKNIX_GUEST_COLDPLUG_TIMEOUT_SECONDS:-30}"
+
+log() {
+  printf '%s: %s\n' "${LOG_TAG}" "$*"
+}
+
+find_guest_pid() {
+  nspawn_pid=$(systemctl show -P MainPID "${GUEST_SERVICE}" 2>/dev/null || true)
+  [ -n "${nspawn_pid}" ] || return 1
+  [ "${nspawn_pid}" != "0" ] || return 1
+
+  # systemd-nspawn is the service main process; guest PID 1 is its direct child.
+  pgrep -P "${nspawn_pid}" | head -n 1
+}
+
+run_guest() {
+  guest_pid=$1
+  shift
+  nsenter --target "${guest_pid}" --mount --uts --ipc --net --pid -- "$@"
+}
+
+end=$(( $(date +%s) + TIMEOUT_SECONDS ))
+guest_pid=""
+while [ "$(date +%s)" -le "${end}" ]; do
+  guest_pid=$(find_guest_pid || true)
+  if [ -n "${guest_pid}" ] \
+    && run_guest "${guest_pid}" test -x /run/current-system/sw/bin/udevadm 2>/dev/null; then
+    break
+  fi
+  sleep 1
+done
+
+if [ -z "${guest_pid}" ]; then
+  log "guest payload PID not found; skipping targeted coldplug"
+  exit 0
+fi
+
+udevadm=/run/current-system/sw/bin/udevadm
+
+# DRM is required for rootless wlroots/libseat. Treat this as the authoritative
+# targeted coldplug operation, but do not fail the host unit if a guest revision
+# lacks DRM or udev is still settling; the guest remains recoverable over SSH.
+if run_guest "${guest_pid}" "${udevadm}" trigger --subsystem-match=drm --action=change; then
+  log "triggered guest DRM coldplug"
+else
+  log "warning: guest DRM coldplug trigger failed"
+fi
+
+# Existing input devices benefit from the same writable uevent passthrough, but
+# virtual input devices created later by guest InputPlumber can appear after the
+# nspawn bind list was constructed. Poke only files that are writable and ignore
+# late/virtual read-only misses.
+run_guest "${guest_pid}" /bin/sh -c '
+  for uevent_path in /sys/class/input/input*/uevent /sys/class/input/event*/uevent; do
+    [ -e "${uevent_path}" ] || continue
+    [ -w "${uevent_path}" ] || continue
+    printf change > "${uevent_path}" 2>/dev/null || true
+  done
+' || log "warning: guest input coldplug poke failed"
+
+run_guest "${guest_pid}" "${udevadm}" settle --timeout=10 || log "warning: guest udev settle timed out"
+
+exit 0
