 check_grep '--directory=${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}' "${SCRIPT_ROOT}/rocknix-guest-start" "guest start helper must target the nix-on-rock active root"
