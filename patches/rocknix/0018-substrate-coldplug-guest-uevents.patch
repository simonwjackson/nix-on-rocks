--- a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-guest.service
@@ -173,6 +173,12 @@ ExecStartPre=/usr/bin/rocknix-guest-prep
 
 ExecStart=/usr/bin/rocknix-guest-start
 
+# nspawn's read-only sysfs prevents the guest's generic systemd-udev-trigger
+# from synthesizing every coldplug event. Once the payload is alive, run a
+# targeted guest-owned coldplug for explicitly passed-through DRM/input devices
+# so logind/libseat can classify seat0 without broad writable /sys access.
+ExecStartPost=/usr/bin/rocknix-guest-coldplug
+
 Restart=on-failure
 RestartSec=2s
 TimeoutStartSec=60s
