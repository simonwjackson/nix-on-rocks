diff --git a/projects/ROCKNIX/devices/SM8550/patches/linux/0054-edt-ft5x06-honour-DT-input-name.patch b/projects/ROCKNIX/devices/SM8550/patches/linux/0054-edt-ft5x06-honour-DT-input-name.patch
new file mode 100644
index 0000000000..ab33921c4a
--- /dev/null
+++ b/projects/ROCKNIX/devices/SM8550/patches/linux/0054-edt-ft5x06-honour-DT-input-name.patch
@@ -0,0 +1,12 @@
+--- a/drivers/input/touchscreen/edt-ft5x06.c
++++ b/drivers/input/touchscreen/edt-ft5x06.c
+@@ -1351 +1351,8 @@
+-	input->name = tsdata->name;
++	/*
++	 * Allow devicetree to override the input device name. Lets boards
++	 * with multiple ft5x06 controllers (which all otherwise report the
++	 * same chip-detected model name) hand Wayland compositors distinct
++	 * vendor:product:name identifiers for per-device routing.
++	 */
++	if (device_property_read_string(&client->dev, "input-name", &input->name))
++		input->name = tsdata->name;
