+    *) return 1 ;;
+  esac
+  seed_lists_compatible "rockchip,rk3566-rk817-tablet" || return 1
+  has_device_compatible "anbernic,rg353p" || return 1
+  has_device_compatible "rockchip,rk3566" || return 1
+  return 0
+}
