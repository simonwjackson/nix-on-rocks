index 0000000000..4a664c564d
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-generation-switch
@@ -0,0 +1,163 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# Manual selected-generation switch helper for the Stage 10 SM8550 A->B->A proof.
+# It updates only the canonical selected profile.
+
+set -eu
+
+PATH="${ROCKNIX_GUEST_HOST_PATH:-/usr/bin:/usr/sbin:/bin:/sbin}"
+
+if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+  . "${ROCKNIX_GUEST_PATHS_FILE}"
+elif [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+  . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+else
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  [ -r "${script_dir}/nix-on-rock-paths" ] && . "${script_dir}/nix-on-rock-paths"
+fi
+
+NIX_ON_ROCK_CURRENT_ROOT="${NIX_ON_ROCK_CURRENT_ROOT:-/storage/nix-on-rock/rootfs/current}"
+NIX_ON_ROCK_MANUAL_HOLD_FILE="${NIX_ON_ROCK_MANUAL_HOLD_FILE:-/storage/nix-on-rock/requests/manual-generation-hold}"
+NIX_ON_ROCK_SWITCH_STATE_FILE="${NIX_ON_ROCK_SWITCH_STATE_FILE:-/storage/nix-on-rock/state/generation-switch-a}"
+
+GUEST_ROOT="${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}"
+GUEST_SERVICE="${ROCKNIX_GUEST_SERVICE:-rocknix-guest.service}"
+PROMOTE_SERVICE="${ROCKNIX_GUEST_PROMOTE_SERVICE:-rocknix-guest-promote.service}"
+SELECTED_PROFILE_GUEST="${ROCKNIX_GUEST_SYSTEM_PROFILE:-/nix/var/nix/profiles/per-user/root/rocknix-guest-system}"
+MANUAL_HOLD_FILE="${ROCKNIX_GUEST_MANUAL_HOLD_FILE:-${NIX_ON_ROCK_MANUAL_HOLD_FILE}}"
+SWITCH_STATE_FILE="${ROCKNIX_GUEST_SWITCH_STATE:-${NIX_ON_ROCK_SWITCH_STATE_FILE}}"
+SYSTEM_PATH=""
+RESTORE=0
+RESTART=1
+LOG_TAG="rocknix-guest-generation-switch"
+
+usage() {
+  cat <<EOF
+Usage: ${LOG_TAG} --to /nix/store/<toplevel> [--no-restart]
+       ${LOG_TAG} --restore [--no-restart]
+
+Requires the manual-generation hold file:
+  ${MANUAL_HOLD_FILE}
+EOF
+}
+
+log() { printf '%s: %s\n' "${LOG_TAG}" "$*"; }
+fail() { log "FAIL: $*"; exit 1; }
+
+while [ $# -gt 0 ]; do
+  case "$1" in
+    --to) SYSTEM_PATH="$2"; shift 2 ;;
+    --restore) RESTORE=1; shift ;;
+    --no-restart) RESTART=0; shift ;;
+    -h|--help) usage; exit 0 ;;
+    *) fail "unknown arg: $1" ;;
+  esac
+done
+
+[ "${RESTORE}" = "1" ] || [ -n "${SYSTEM_PATH}" ] || fail "--to or --restore is required"
+[ "${RESTORE}" = "0" ] || [ -z "${SYSTEM_PATH}" ] || fail "--restore cannot be combined with --to"
+[ -e "${MANUAL_HOLD_FILE}" ] || fail "manual-generation hold is required: ${MANUAL_HOLD_FILE}"
+[ -d "${GUEST_ROOT}" ] || fail "guest rootfs missing: ${GUEST_ROOT}"
+[ -d "${GUEST_ROOT}/nix" ] || fail "guest /nix missing under ${GUEST_ROOT}"
+
+profile_host_path() {
+  case "$1" in
+    /nix/*) printf '%s%s\n' "${GUEST_ROOT}" "$1" ;;
+    *) fail "profile path must be guest-absolute under /nix: $1" ;;
+  esac
+}
+
+resolve_profile() {
+  profile_guest_path="$1"
+  profile_path="$(profile_host_path "${profile_guest_path}")"
+  [ -L "${profile_path}" ] || return 1
+  target="$(readlink "${profile_path}" 2>/dev/null || true)"
+  case "${target}" in
+    /nix/*) resolved="${target}" ;;
+    '') return 1 ;;
+    *) resolved="$(readlink "$(dirname "${profile_path}")/${target}" 2>/dev/null || true)" ;;
+  esac
+  case "${resolved}" in /nix/*) : ;; *) return 1 ;; esac
+  [ -x "${GUEST_ROOT}${resolved}/init" ] || return 1
+  printf '%s\n' "${resolved}"
+}
+
+ensure_no_active_promotion() {
+  if systemctl is-active --quiet "${PROMOTE_SERVICE}" 2>/dev/null; then
+    log "stopping in-flight ${PROMOTE_SERVICE} before manual generation switch"
+    systemctl stop "${PROMOTE_SERVICE}" || true
+  fi
+
+  i=0
+  while systemctl is-active --quiet "${PROMOTE_SERVICE}" 2>/dev/null; do
+    [ "${i}" -lt 60 ] || fail "${PROMOTE_SERVICE} is still active"
+    i=$((i + 1))
+    sleep 1
+  done
+}
+
+ensure_guest_namespace() {
+  outer_pid="$(systemctl show -p MainPID --value "${GUEST_SERVICE}" 2>/dev/null || true)"
+  case "${outer_pid}" in ''|0) return 1 ;; esac
+  inner_pid="$(pgrep -P "${outer_pid}" | head -1 || true)"
+  [ -n "${inner_pid}" ] || return 1
+  return 0
+}
+
+host_set_profile() {
+  profile_guest="$1"
+  link_name="$2"
+  target_system="$3"
+  profile_path="$(profile_host_path "${profile_guest}")"
+  profile_dir="$(dirname "${profile_path}")"
+  mkdir -p "${profile_dir}"
+  ln -sfn "${target_system}" "${profile_dir}/${link_name}"
+  ln -sfn "${link_name}" "${profile_path}"
+}
+
+set_profiles() {
+  target_system="$1"
+  if ensure_guest_namespace; then
+    nsenter -t "${inner_pid}" -m -u -i -n -p sh -c "set -eu; export PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/bin:/usr/bin; /run/current-system/sw/bin/mkdir -p /nix/var/nix/profiles/per-user/root; /run/current-system/sw/bin/nix-env -p '${SELECTED_PROFILE_GUEST}' --set '${target_system}'"
+  else
+    [ "${RESTORE}" = "1" ] || fail "guest is not running; only --restore may use host-side profile fallback"
+    host_set_profile "${SELECTED_PROFILE_GUEST}" "rocknix-guest-system-manual-link" "${target_system}"
+  fi
+}
+
+selected="$(resolve_profile "${SELECTED_PROFILE_GUEST}" || true)"
+running=""
+if ensure_guest_namespace; then
+  running="$(readlink "/proc/${inner_pid}/root/run/current-system" 2>/dev/null || true)"
+fi
+
+if [ "${RESTORE}" = "1" ]; then
+  [ -r "${SWITCH_STATE_FILE}" ] || fail "switch state file missing: ${SWITCH_STATE_FILE}"
+  SYSTEM_PATH="$(sed -n '1p' "${SWITCH_STATE_FILE}" | tr -d '[:space:]')"
+  [ -n "${SYSTEM_PATH}" ] || fail "switch state file is empty: ${SWITCH_STATE_FILE}"
+else
+  case "${SYSTEM_PATH}" in /nix/store/*) : ;; *) fail "target must be guest-absolute under /nix/store: ${SYSTEM_PATH}" ;; esac
+  if [ ! -r "${SWITCH_STATE_FILE}" ]; then
+    [ -n "${selected}" ] || fail "selected profile is missing before recording generation A"
+    [ -n "${running}" ] || fail "running guest generation is missing before recording generation A"
+    [ "${selected}" = "${running}" ] || fail "selected/running differ before recording generation A: selected=${selected} running=${running}"
+    mkdir -p "$(dirname "${SWITCH_STATE_FILE}")"
+    printf '%s\n' "${selected}" > "${SWITCH_STATE_FILE}"
+    log "recorded generation A: ${selected}"
+  fi
+fi
+
+case "${SYSTEM_PATH}" in /nix/store/*) : ;; *) fail "target must be guest-absolute under /nix/store: ${SYSTEM_PATH}" ;; esac
+[ -x "${GUEST_ROOT}${SYSTEM_PATH}/init" ] || fail "target init is not executable: ${GUEST_ROOT}${SYSTEM_PATH}/init"
+
+ensure_no_active_promotion
+set_profiles "${SYSTEM_PATH}"
+log "selected guest profile now points at ${SYSTEM_PATH}"
+
+if [ "${RESTART}" = "1" ]; then
+  systemctl reset-failed "${GUEST_SERVICE}" 2>/dev/null || true
+  systemctl restart --no-block "${GUEST_SERVICE}"
+  log "restarting ${GUEST_SERVICE} to boot ${SYSTEM_PATH}"
+fi
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-prep b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-prep
new file mode 100755
index 0000000000..1d684ea8de
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-prep
@@ -0,0 +1,178 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# SM8550 guest ExecStartPre helper for rocknix-guest.service.
+#
+# This helper is intentionally pure shell: no host Nix dependency, no
+# /run/current-system dependency. It runs before the guest boots.
+#
+# Stage 10 selector spike:
+#   The host does not own a root /nix store. It resolves guest generations
+#   through the persistent guest rootfs. The selected guest generation is the
+#   guest-absolute profile below, read by the host as ${GUEST_ROOT}${path}.
+#   The old guest-local system profile is retired as a boot authority: the
+#   host starts only the explicit selected guest-system profile.
+
+set -eu
+
+if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+  . "${ROCKNIX_GUEST_PATHS_FILE}"
+elif [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+  . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+else
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  [ -r "${script_dir}/nix-on-rock-paths" ] && . "${script_dir}/nix-on-rock-paths"
+fi
+
+NIX_ON_ROCK_CURRENT_ROOT="${NIX_ON_ROCK_CURRENT_ROOT:-/storage/nix-on-rock/rootfs/current}"
+NIX_ON_ROCK_GUEST_EXCHANGE_DIR="${NIX_ON_ROCK_GUEST_EXCHANGE_DIR:-/storage/nix-on-rock/staging/guest-exchange}"
+NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH="${NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH:-/storage/.guest}"
+
+GUEST_ROOT="${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}"
+SELECTED_PROFILE_GUEST="${ROCKNIX_GUEST_SYSTEM_PROFILE:-/nix/var/nix/profiles/per-user/root/rocknix-guest-system}"
+GUEST_RUN_DIR="${GUEST_ROOT}/run"
+GUEST_STORAGE_ROOT="${GUEST_ROOT}/storage"
+RESOLV_OWN_MARKER="${GUEST_ROOT}/etc/resolv.conf.guest-owned"
+GUEST_AREA="${ROCKNIX_GUEST_AREA:-${NIX_ON_ROCK_GUEST_EXCHANGE_DIR}}"
+LOG_TAG="rocknix-guest-prep"
+
+log() {
+  printf '%s %s\n' "${LOG_TAG}:" "$*"
+}
+
+warn() {
+  printf '%s %s\n' "${LOG_TAG}:" "$*" >&2
+}
+
+fail() {
+  log "FAIL: $*"
+  exit 1
+}
+
+profile_host_path() {
+  case "$1" in
+    /nix/*) printf '%s%s\n' "${GUEST_ROOT}" "$1" ;;
+    *) fail "profile path must be guest-absolute under /nix: $1" ;;
+  esac
+}
+
+resolve_system_profile() {
+  profile_guest_path="$1"
+  label="$2"
+  profile_path="$(profile_host_path "${profile_guest_path}")"
+
+  [ -L "${profile_path}" ] || return 1
+
+  # Read the symlink target without -f resolution so we get the absolute
+  # /nix/store/... path as written for the guest, not as the host would
+  # resolve it.
+  link_target="$(readlink "${profile_path}" 2>/dev/null || true)"
+  case "${link_target}" in
+    /nix/*)
+      desired_system="${link_target}"
+      ;;
+    '')
+      return 1
+      ;;
+    *)
+      # Indirect symlink (profile -> profile-N-link -> /nix/store/...).
+      profile_dir="$(dirname "${profile_path}")"
+      desired_system="$(readlink "${profile_dir}/${link_target}" 2>/dev/null || true)"
+      ;;
+  esac
+
+  case "${desired_system}" in
+    /nix/*) : ;;
+    *)
+      warn "WARNING: ${label} profile resolves outside /nix: ${desired_system:-unresolved}"
+      return 1
+      ;;
+  esac
+
+  if [ -d "${GUEST_ROOT}${desired_system}" ] && [ -x "${GUEST_ROOT}${desired_system}/init" ]; then
+    printf '%s\n' "${desired_system}"
+    return 0
+  fi
+
+  warn "WARNING: ${label} profile resolves to unusable system: ${desired_system}"
+  warn "  expected ${GUEST_ROOT}${desired_system}/init to be executable"
+  return 1
+}
+
+relink_guest_init() {
+  desired_system="$1"
+  desired="${desired_system}/init"
+
+  for init_path in "${GUEST_ROOT}/init" "${GUEST_ROOT}/sbin/init"; do
+    if [ -e "${init_path}" ] && [ ! -L "${init_path}" ]; then
+      fail "guest init path is not a symlink: ${init_path}"
+    fi
+
+    cur="$(readlink "${init_path}" 2>/dev/null || true)"
+    if [ "${cur}" != "${desired}" ]; then
+      log "relinking ${init_path}: ${cur:-missing} -> ${desired}"
+      ln -sfn "${desired}" "${init_path}"
+    fi
+  done
+}
+
+# Guest rootfs sanity. ConditionPathExists in the unit also covers this,
+# but if the rootfs is partially populated we want a clearer failure.
+[ -d "${GUEST_ROOT}" ] || fail "guest rootfs missing: ${GUEST_ROOT}"
+[ -d "${GUEST_ROOT}/nix" ] || fail "guest /nix missing under ${GUEST_ROOT}"
+[ -d "${GUEST_ROOT}/etc" ] || fail "guest /etc missing under ${GUEST_ROOT}"
+
+# Ensure the selected profile namespace exists in the guest rootfs view. This
+# does not create or rely on a host root /nix mount.
+selected_profile_path="$(profile_host_path "${SELECTED_PROFILE_GUEST}")"
+mkdir -p "$(dirname "${selected_profile_path}")"
+chmod 0755 "$(dirname "${selected_profile_path}")"
+
+selected_system="$(resolve_system_profile "${SELECTED_PROFILE_GUEST}" "selected guest system" || true)"
+[ -n "${selected_system}" ] || fail "no valid selected guest system profile found at ${SELECTED_PROFILE_GUEST}"
+log "selected guest system profile: ${selected_system}"
+relink_guest_init "${selected_system}"
+
+# Guest exchange area on host /storage. This is the only host storage seam we
+# bind into the guest; product ROM/config/state paths should be guest-owned or
+# guest-mounted rather than app-specific host binds.
+if [ ! -d "${GUEST_AREA}" ]; then
+  log "creating guest writable area at ${GUEST_AREA}"
+  mkdir -p "${GUEST_AREA}"
+  chmod 0755 "${GUEST_AREA}"
+fi
+
+# The guest owns its own /storage namespace. Ensure the persistent guest rootfs
+# has the expected home/config/cache mountpoints before nspawn starts; only
+# ${NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH} is over-mounted by the host bind for
+# compatibility handoff files during the transition.
+for dir in \
+  "${GUEST_STORAGE_ROOT}" \
+  "${GUEST_ROOT}${NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH}" \
+  "${GUEST_STORAGE_ROOT}/.config" \
+  "${GUEST_STORAGE_ROOT}/.local" \
+  "${GUEST_STORAGE_ROOT}/.cache" \
+  "${GUEST_STORAGE_ROOT}/roms"; do
+  if [ ! -d "${dir}" ]; then
+    log "creating guest-owned storage path ${dir}"
+    mkdir -p "${dir}"
+    chmod 0755 "${dir}"
+  fi
+done
+
+# The guest's /run is tmpfs at runtime. The live guest must seed
+# /run/current-system from its selected generation; the host only verifies that
+# the selected profile chain is coherent before nspawn starts.
+log "guest selected profile present: ${selected_system}"
+
+# Ownership marker for /etc/resolv.conf. The guest config sets this
+# file declaratively; if anything host-side ever clobbers it, the
+# marker file lets the soak harness detect the bleed by sampling the
+# mtime/checksum.
+if [ ! -f "${RESOLV_OWN_MARKER}" ]; then
+  log "writing resolv.conf ownership marker"
+  printf 'guest-owned: %s\n' "$(date -u +%FT%TZ)" > "${RESOLV_OWN_MARKER}"
+fi
+
+log "prep complete"
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-promote b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-promote
new file mode 100755
index 0000000000..d741131510
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-promote
@@ -0,0 +1,260 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# Promote the host-packaged rocknix-nix-guest source into the persistent
+# /storage-backed NixOS guest rootfs.
+#
+# ROCKNIX image updates replace /usr/lib/rocknix-guest-substrate/guest, but they do
+# not overwrite /storage/nix-on-rock/rootfs/current. This helper bridges that
+# lifecycle boundary after the old guest has booted and networking is owned by
+# the guest: it builds the packaged main-space NixOS configuration inside the
+# running guest, points the selected guest-system profile at the new toplevel,
+# then asks the host to restart the guest once so PID 1 boots the selected
+# generation. The selected profile is the only host-recognized guest system
+# authority; /nix/var/nix/profiles/system is intentionally not repaired.
+
+set -eu
+
+PATH="${ROCKNIX_GUEST_HOST_PATH:-/usr/bin:/usr/sbin:/bin:/sbin}"
+
+if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+  . "${ROCKNIX_GUEST_PATHS_FILE}"
+elif [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+  . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+else
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  [ -r "${script_dir}/nix-on-rock-paths" ] && . "${script_dir}/nix-on-rock-paths"
+fi
+
+NIX_ON_ROCK_CURRENT_ROOT="${NIX_ON_ROCK_CURRENT_ROOT:-/storage/nix-on-rock/rootfs/current}"
+NIX_ON_ROCK_STAGED_SOURCE="${NIX_ON_ROCK_STAGED_SOURCE:-/storage/nix-on-rock/staging/guest-exchange/rocknix-nix-guest-packaged}"
+NIX_ON_ROCK_PROMOTE_SYSTEM_PATH_FILE="${NIX_ON_ROCK_PROMOTE_SYSTEM_PATH_FILE:-/storage/nix-on-rock/staging/guest-exchange/rocknix-guest-promote-system-path}"
+NIX_ON_ROCK_MANUAL_HOLD_FILE="${NIX_ON_ROCK_MANUAL_HOLD_FILE:-/storage/nix-on-rock/requests/manual-generation-hold}"
+NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH="${NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH:-/storage/.guest}"
+
+GUEST_ROOT="${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}"
+GUEST_SOURCE="${ROCKNIX_GUEST_SOURCE:-/usr/lib/rocknix-guest-substrate/guest}"
+GUEST_REV_FILE="${ROCKNIX_GUEST_REV_FILE:-/usr/lib/rocknix-guest-substrate/guest-revision}"
+GUEST_SERVICE="${ROCKNIX_GUEST_SERVICE:-rocknix-guest.service}"
+STAGED_SOURCE="${ROCKNIX_GUEST_STAGED_SOURCE:-${NIX_ON_ROCK_STAGED_SOURCE}}"
+APPLIED_REV_FILE="${ROCKNIX_GUEST_APPLIED_REV_FILE:-${GUEST_ROOT}/etc/rocknix-guest-revision}"
+APPLIED_SYSTEM_FILE="${ROCKNIX_GUEST_APPLIED_SYSTEM_FILE:-${GUEST_ROOT}/etc/rocknix-guest-system-path}"
+SEED_CONTRACT_MARKER="${ROCKNIX_GUEST_SEED_CONTRACT_MARKER:-${GUEST_ROOT}/.rocknix-guest-rootfs-seed}"
+PROMOTE_SYSTEM_PATH_FILE="${ROCKNIX_GUEST_PROMOTE_SYSTEM_PATH:-${NIX_ON_ROCK_PROMOTE_SYSTEM_PATH_FILE}}"
+GUEST_PROMOTE_SYSTEM_PATH_FILE="${ROCKNIX_GUEST_PROMOTE_SYSTEM_PATH_GUEST:-${NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH}/rocknix-guest-promote-system-path}"
+GUEST_STAGED_SOURCE="${ROCKNIX_GUEST_STAGED_SOURCE_GUEST:-${NIX_ON_ROCK_GUEST_EXCHANGE_GUEST_PATH}/rocknix-nix-guest-packaged}"
+MANUAL_HOLD_FILE="${ROCKNIX_GUEST_MANUAL_HOLD_FILE:-${NIX_ON_ROCK_MANUAL_HOLD_FILE}}"
+LEGACY_MANUAL_HOLD_FILE="${ROCKNIX_GUEST_LEGACY_MANUAL_HOLD_FILE:-/storage/.guest/rocknix-guest-manual-generation-hold}"
+SELECTED_PROFILE_GUEST="${ROCKNIX_GUEST_SYSTEM_PROFILE:-/nix/var/nix/profiles/per-user/root/rocknix-guest-system}"
+DEVICE_COMPATIBLE_FILE="${ROCKNIX_GUEST_DEVICE_COMPATIBLE_FILE:-/proc/device-tree/compatible}"
+LOG_TAG="rocknix-guest-promote"
+
+log() {
+  printf '%s: %s\n' "${LOG_TAG}" "$*"
+}
+
+fail() {
+  log "FAIL: $*"
+  exit 1
+}
+
+read_first_line() {
+  file="$1"
+  if [ -r "${file}" ]; then
+    sed -n '1p' "${file}" | tr -d '[:space:]'
+  fi
+}
+
+profile_host_path() {
+  case "$1" in
+    /nix/*) printf '%s%s\n' "${GUEST_ROOT}" "$1" ;;
+    *) fail "profile path must be guest-absolute under /nix: $1" ;;
+  esac
+}
+
+resolve_guest_system_profile() {
+  profile_guest_path="$1"
+  profile_path="$(profile_host_path "${profile_guest_path}")"
+  [ -L "${profile_path}" ] || return 1
+
+  target="$(readlink "${profile_path}" 2>/dev/null || true)"
+  case "${target}" in
+    /nix/*)
+      printf '%s\n' "${target}"
+      return 0
+      ;;
+    '')
+      return 1
+      ;;
+    *)
+      profile_dir="$(dirname "${profile_path}")"
+      indirect="$(readlink "${profile_dir}/${target}" 2>/dev/null || true)"
+      case "${indirect}" in
+        /nix/*)
+          printf '%s\n' "${indirect}"
+          return 0
+          ;;
+      esac
+      ;;
+  esac
+
+  return 1
+}
+
+guest_system_path_valid() {
+  guest_path="$1"
+  case "${guest_path}" in
+    /nix/*) [ -x "${GUEST_ROOT}${guest_path}/init" ] ;;
+    *) return 1 ;;
+  esac
+}
+
+seed_contract_value() {
+  key="$1"
+  [ -r "${SEED_CONTRACT_MARKER}" ] || return 0
+  sed -n "s/^${key}=//p" "${SEED_CONTRACT_MARKER}" 2>/dev/null | sed -n '1p'
+}
+
+manual_generation_hold_active() {
+  [ -e "${MANUAL_HOLD_FILE}" ] || [ -e "${LEGACY_MANUAL_HOLD_FILE}" ]
+}
+
+exit_if_manual_generation_hold_active() {
+  if manual_generation_hold_active; then
+    log "manual generation selection hold is active: ${MANUAL_HOLD_FILE}"
+    log "skipping packaged guest promotion without changing profiles, markers, or guest service"
+    exit 0
+  fi
+}
+
+ensure_guest_namespace() {
+  outer_pid="$(systemctl show -p MainPID --value "${GUEST_SERVICE}" 2>/dev/null || true)"
+  case "${outer_pid}" in
+    ''|0) fail "${GUEST_SERVICE} is not running" ;;
+  esac
+
+  inner_pid="$(pgrep -P "${outer_pid}" | head -1 || true)"
+  [ -n "${inner_pid}" ] || fail "could not find guest payload PID under ${outer_pid}"
+}
+
+first_device_compatible() {
+  [ -r "${DEVICE_COMPATIBLE_FILE}" ] || fail "device compatible file missing: ${DEVICE_COMPATIBLE_FILE}"
+  tr '\000' '\n' < "${DEVICE_COMPATIBLE_FILE}" | sed -n '/./{p;q;}'
+}
+
+[ -d "${GUEST_ROOT}" ] || fail "guest rootfs missing: ${GUEST_ROOT}"
+[ -d "${GUEST_SOURCE}" ] || fail "packaged guest source missing: ${GUEST_SOURCE}"
+[ -r "${GUEST_REV_FILE}" ] || fail "packaged guest revision missing: ${GUEST_REV_FILE}"
+
+case "${SELECTED_PROFILE_GUEST}" in
+  /nix/*) : ;;
+  *) fail "selected profile must live under guest /nix: ${SELECTED_PROFILE_GUEST}" ;;
+esac
+
+wanted_rev="$(sed -n '1p' "${GUEST_REV_FILE}" | tr -d '[:space:]')"
+[ -n "${wanted_rev}" ] || fail "empty packaged guest revision"
+
+exit_if_manual_generation_hold_active
+
+current_rev="$(read_first_line "${APPLIED_REV_FILE}")"
+current_system="$(resolve_guest_system_profile "${SELECTED_PROFILE_GUEST}" || true)"
+
+if [ "${current_rev}" = "${wanted_rev}" ]; then
+  if [ -n "${current_system}" ] && guest_system_path_valid "${current_system}"; then
+    log "guest revision already applied: ${wanted_rev}; selected profile is ${current_system}"
+    exit 0
+  fi
+
+  fail "guest revision marker matches ${wanted_rev}, but selected profile is missing or invalid; refusing to use applied markers as source of truth"
+fi
+
+seed_rev="$(seed_contract_value revision)"
+if [ -z "${current_rev}" ] && [ "${seed_rev}" = "${wanted_rev}" ] && [ -n "${current_system}" ] && guest_system_path_valid "${current_system}"; then
+  printf '%s\n' "${wanted_rev}" > "${APPLIED_REV_FILE}"
+  printf '%s\n' "${current_system}" > "${APPLIED_SYSTEM_FILE}"
+  log "packaged guest revision ${wanted_rev} is already booted from matching offline seed; selected profile is ${current_system}"
+  exit 0
+fi
+
+log "promoting guest revision ${wanted_rev} (current: ${current_rev:-none})"
+
+mkdir -p "$(dirname "${STAGED_SOURCE}")"
+tmp_source="${STAGED_SOURCE}.tmp.$$"
+rm -rf "${tmp_source}"
+mkdir -p "${tmp_source}"
+cp -PR "${GUEST_SOURCE}/." "${tmp_source}/"
+printf '%s\n' "${wanted_rev}" > "${tmp_source}/.rocknix-guest-revision"
+rm -rf "${STAGED_SOURCE}.previous"
+if [ -d "${STAGED_SOURCE}" ]; then
+  mv "${STAGED_SOURCE}" "${STAGED_SOURCE}.previous"
+fi
+mv "${tmp_source}" "${STAGED_SOURCE}"
+
+if [ -x "${STAGED_SOURCE}/scripts/static-checks.sh" ]; then
+  log "running packaged guest static checks"
+  "${STAGED_SOURCE}/scripts/static-checks.sh"
+fi
+
+ensure_guest_namespace
+
+log "waiting for guest NetworkManager before Nix build"
+nsenter -t "${inner_pid}" -m -u -i -n -p sh -c '
+  set -eu
+  export PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/bin:/usr/bin
+  i=0
+  while [ "${i}" -lt 60 ]; do
+    if [ -x /run/current-system/sw/bin/systemctl ] && /run/current-system/sw/bin/systemctl is-active NetworkManager.service >/dev/null 2>&1; then
+      exit 0
+    fi
+    i=$((i + 1))
+    if [ -x /run/current-system/sw/bin/sleep ]; then
+      /run/current-system/sw/bin/sleep 2
+    else
+      sleep 2 2>/dev/null || true
+    fi
+  done
+  exit 1
+' || fail "guest NetworkManager did not become active"
+
+# Build target: the by-compatible dispatch entry point in rocknix-nix-guest.
+# It reads /proc/device-tree/compatible at eval time (visible inside the
+# guest namespace because systemd-nspawn shares the host DT) and selects
+# the matching profile from deviceProfileByCompatible. Requires --impure
+# because the eval depends on a path outside the Nix store. See
+# docs/contracts/layer14-main-space-contract.md in rocknix-nix-guest for
+# the device-addition workflow; the host substrate must not maintain a
+# parallel device list.
+device_compatible="$(first_device_compatible)"
+[ -n "${device_compatible}" ] || fail "empty device compatible string from ${DEVICE_COMPATIBLE_FILE}"
+log "building packaged guest inside running guest namespace for compatible ${device_compatible}"
+nsenter -t "${inner_pid}" -m -u -i -n -p sh -c "
+  set -eu
+  export PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/bin:/usr/bin
+  export ROCKNIX_GUEST_DEVICE_COMPATIBLE='${device_compatible}'
+  cd '${GUEST_STAGED_SOURCE}'
+  /run/current-system/sw/bin/nix build --impure --extra-experimental-features \"nix-command flakes\" \
+    .#nixosConfigurations.rocknix-guest-main-space-by-compatible.config.system.build.toplevel \
+    --print-out-paths
+  system_path=\"\$(/run/current-system/sw/bin/readlink -f result)\"
+  [ -n \"\${system_path}\" ]
+  printf \"%s\\n\" \"\${system_path}\" > '${GUEST_PROMOTE_SYSTEM_PATH_FILE}'
+"
+
+system_path=""
+if [ -r "${PROMOTE_SYSTEM_PATH_FILE}" ]; then
+  system_path="$(sed -n '1p' "${PROMOTE_SYSTEM_PATH_FILE}")"
+  rm -f "${PROMOTE_SYSTEM_PATH_FILE}"
+fi
+[ -n "${system_path}" ] || fail "guest build did not report a system path"
+
+exit_if_manual_generation_hold_active
+nsenter -t "${inner_pid}" -m -u -i -n -p sh -c "set -eu; export PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/default/bin:/bin:/usr/bin; /run/current-system/sw/bin/mkdir -p /nix/var/nix/profiles/per-user/root; /run/current-system/sw/bin/nix-env -p '${SELECTED_PROFILE_GUEST}' --set '${system_path}'"
+exit_if_manual_generation_hold_active
+
+printf '%s\n' "${wanted_rev}" > "${APPLIED_REV_FILE}"
+printf '%s\n' "${system_path}" > "${APPLIED_SYSTEM_FILE}"
+
+log "selected guest profile now points at ${system_path}"
+log "restarting guest to boot promoted generation"
+systemctl restart --no-block "${GUEST_SERVICE}"
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-root-ensure b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-root-ensure
new file mode 100755
index 0000000000..e7d15d0dba
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-root-ensure
@@ -0,0 +1,512 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# Ensure the persistent SM8550 NixOS guest rootfs exists before the guest
+# service starts. This is the first-boot bridge from the immutable host image
+# to /storage/nix-on-rock/rootfs/current; promotion remains responsible only for
+# updating an already bootable guest.
+
+set -eu
+
+PATH="${ROCKNIX_GUEST_HOST_PATH:-/usr/bin:/usr/sbin:/bin:/sbin}"
+
+if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+  . "${ROCKNIX_GUEST_PATHS_FILE}"
+elif [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+  . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+else
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  [ -r "${script_dir}/nix-on-rock-paths" ] && . "${script_dir}/nix-on-rock-paths"
+fi
+
+NIX_ON_ROCK_ROOT="${NIX_ON_ROCK_ROOT:-/storage/nix-on-rock}"
+NIX_ON_ROCK_ROOTFS_DIR="${NIX_ON_ROCK_ROOTFS_DIR:-${NIX_ON_ROCK_ROOT}/rootfs}"
+NIX_ON_ROCK_CURRENT_ROOT="${NIX_ON_ROCK_CURRENT_ROOT:-${NIX_ON_ROCK_ROOTFS_DIR}/current}"
+NIX_ON_ROCK_PREVIOUS_ROOT="${ROCKNIX_GUEST_PREVIOUS_ROOT:-${NIX_ON_ROCK_PREVIOUS_ROOT:-${NIX_ON_ROCK_ROOTFS_DIR}/previous}}"
+NIX_ON_ROCK_SEED_DIR="${NIX_ON_ROCK_SEED_DIR:-${NIX_ON_ROCK_ROOT}/images/seeds}"
+
+GUEST_ROOT="${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}"
+SEED_DIR="${ROCKNIX_GUEST_ROOTFS_SEED_DIR:-${NIX_ON_ROCK_SEED_DIR}}"
+SEED_MANIFEST="${ROCKNIX_GUEST_ROOTFS_SEED_MANIFEST:-/usr/lib/rocknix-guest-substrate/guest-rootfs-seed.manifest}"
+SEED_ROOT="${ROCKNIX_GUEST_ROOTFS_SEED:-}"
+SEED_ARCHIVE="${ROCKNIX_GUEST_ROOTFS_SEED_ARCHIVE:-}"
+SEED_ARCHIVE_MARKER="${ROCKNIX_GUEST_ROOTFS_SEED_ARCHIVE_MARKER:-}"
+DEVICE_COMPATIBLE="${ROCKNIX_GUEST_DEVICE_COMPATIBLE:-}"
+DEVICE_COMPATIBLE_FILE="${ROCKNIX_GUEST_DEVICE_COMPATIBLE_FILE:-/proc/device-tree/compatible}"
+RESEED_FLAG="${ROCKNIX_GUEST_RESEED_FLAG:-/flash/rocknix.reseed-guest}"
+SELECTED_PROFILE_GUEST="${ROCKNIX_GUEST_SYSTEM_PROFILE:-/nix/var/nix/profiles/per-user/root/rocknix-guest-system}"
+LOCK_FILE="${ROCKNIX_GUEST_ROOT_LOCK:-/run/lock/rocknix-guest-root.lock}"
+GUEST_SERVICE="${ROCKNIX_GUEST_SERVICE:-rocknix-guest.service}"
+SEED_CONTRACT_MARKER=".rocknix-guest-rootfs-seed"
+SEED_IN_PROGRESS_MARKER=".rocknix-guest-rootfs-seed-in-progress"
+SEED_COMPLETE_MARKER="etc/rocknix-guest-root-seed-complete"
+LOG_TAG="rocknix-guest-root-ensure"
+
+MANIFEST_LOADED=0
+EXPECTED_SEED_DEVICE=""
+EXPECTED_SEED_COMPATIBLE=""
+EXPECTED_SEED_REVISION=""
+EXPECTED_SEED_ARCHIVE=""
+EXPECTED_SEED_SHA256=""
+EXPECTED_SEED_SIZE=""
+EXPECTED_SEED_SOURCE_URLS=""
+
+log() {
+  printf '%s: %s\n' "${LOG_TAG}" "$*"
+}
+
+fail() {
+  log "FAIL: $*" >&2
+  exit 1
+}
+
+is_empty_dir() {
+  [ -d "$1" ] || return 1
+  [ -z "$(find "$1" -mindepth 1 -maxdepth 1 2>/dev/null | sed -n '1p')" ]
+}
+
+is_symlink_path() {
+  [ -L "$1" ]
+}
+
+ensure_safe_storage_paths() {
+  case "${GUEST_ROOT}" in
+    "${NIX_ON_ROCK_ROOTFS_DIR}"/*) : ;;
+    *) fail "guest root must live under nix-on-rock rootfs dir: root=${GUEST_ROOT} rootfs=${NIX_ON_ROCK_ROOTFS_DIR}" ;;
+  esac
+
+  storage_root=$(dirname "${NIX_ON_ROCK_ROOT}")
+  for path in "${storage_root}" "${NIX_ON_ROCK_ROOT}" "${NIX_ON_ROCK_ROOTFS_DIR}" "${GUEST_ROOT}" "${NIX_ON_ROCK_PREVIOUS_ROOT}" "${SEED_DIR}"; do
+    if [ -e "${path}" ] && is_symlink_path "${path}"; then
+      fail "storage contract path is a symlink: ${path}"
+    fi
+  done
+
+  mkdir -p "${NIX_ON_ROCK_ROOTFS_DIR}" "${SEED_DIR}"
+  chmod 0755 "${NIX_ON_ROCK_ROOTFS_DIR}" "${SEED_DIR}" 2>/dev/null || true
+}
+
+profile_host_path_for_root() {
+  root="$1"
+  profile="$2"
+  case "${profile}" in
+    /nix/*) printf '%s%s\n' "${root}" "${profile}" ;;
+    *) fail "profile path must be guest-absolute under /nix: ${profile}" ;;
+  esac
+}
+
+resolve_system_profile_for_root() {
+  root="$1"
+  profile_guest_path="$2"
+  profile_path=$(profile_host_path_for_root "${root}" "${profile_guest_path}")
+
+  [ -L "${profile_path}" ] || return 1
+  link_target=$(readlink "${profile_path}" 2>/dev/null || true)
+  case "${link_target}" in
+    /nix/*) desired_system="${link_target}" ;;
+    '') return 1 ;;
+    *)
+      profile_dir=$(dirname "${profile_path}")
+      desired_system=$(readlink "${profile_dir}/${link_target}" 2>/dev/null || true)
+      ;;
+  esac
+
+  case "${desired_system}" in
+    /nix/*) : ;;
+    *) return 1 ;;
+  esac
+
+  [ -d "${root}${desired_system}" ] || return 1
+  [ -x "${root}${desired_system}/init" ] || return 1
+  printf '%s\n' "${desired_system}"
+}
+
+system_from_init_link_for_root() {
+  root="$1"
+
+  for init_path in "${root}/init" "${root}/sbin/init"; do
+    [ -L "${init_path}" ] || continue
+    init_target=$(readlink "${init_path}" 2>/dev/null || true)
+    case "${init_target}" in
+      /nix/*/init)
+        desired_system="${init_target%/init}"
+        [ -d "${root}${desired_system}" ] || continue
+        [ -x "${root}${desired_system}/init" ] || continue
+        printf '%s\n' "${desired_system}"
+        return 0
+        ;;
+    esac
+  done
+
+  return 1
+}
+
+ensure_selected_profile_for_root() {
+  root="$1"
+  profile_guest_path="$2"
+  profile_path=$(profile_host_path_for_root "${root}" "${profile_guest_path}")
+
+  [ -L "${profile_path}" ] && return 0
+  [ ! -e "${profile_path}" ] || return 0
+
+  desired_system=$(system_from_init_link_for_root "${root}" || true)
+  [ -n "${desired_system}" ] || return 0
+
+  mkdir -p "$(dirname "${profile_path}")" || fail "failed to create guest profile directory: ${profile_path}"
+  ln -s "${desired_system}" "${profile_path}" || fail "failed to synthesize guest selected profile: ${profile_path} -> ${desired_system}"
+  log "synthesized missing guest selected profile from init link: ${profile_guest_path} -> ${desired_system}"
+}
+
+validate_init_links_for_root() {
+  root="$1"
+  desired_system="$2"
+  desired="${desired_system}/init"
+
+  for init_path in "${root}/init" "${root}/sbin/init"; do
+    if [ -e "${init_path}" ]; then
+      [ -L "${init_path}" ] || fail "guest init path is not a symlink: ${init_path}"
+      cur=$(readlink "${init_path}" 2>/dev/null || true)
+      [ "${cur}" = "${desired}" ] || fail "guest init path points at ${cur:-missing}, expected ${desired}: ${init_path}"
+    else
+      # Linkable target: prep can create the symlink later, but /sbin must exist.
+      [ "$(dirname "${init_path}")" = "${root}" ] || [ -d "$(dirname "${init_path}")" ] || return 1
+    fi
+  done
+}
+
+validate_rootfs() {
+  root="$1"
+  require_seed_marker="$2"
+
+  [ -d "${root}" ] || fail "guest rootfs missing: ${root}"
+  [ -d "${root}/nix" ] || fail "guest /nix missing under ${root}"
+  [ -d "${root}/etc" ] || fail "guest /etc missing under ${root}"
+  [ -d "${root}/sbin" ] || fail "guest /sbin missing under ${root}"
+
+  if [ "${require_seed_marker}" = "yes" ]; then
+    [ -f "${root}/${SEED_CONTRACT_MARKER}" ] || fail "seed contract marker missing: ${root}/${SEED_CONTRACT_MARKER}"
+  fi
+
+  ensure_selected_profile_for_root "${root}" "${SELECTED_PROFILE_GUEST}"
+  selected_system=$(resolve_system_profile_for_root "${root}" "${SELECTED_PROFILE_GUEST}" || true)
+  [ -n "${selected_system}" ] || fail "no valid selected guest system profile found at ${SELECTED_PROFILE_GUEST} under ${root}"
+  validate_init_links_for_root "${root}" "${selected_system}"
+}
+
+acquire_lock() {
+  lock_dir="${LOCK_FILE}.d"
+  mkdir -p "$(dirname "${LOCK_FILE}")"
+  if ! mkdir "${lock_dir}" 2>/dev/null; then
+    fail "guest root mutation lock is held: ${LOCK_FILE}"
+  fi
+  trap 'rmdir "${lock_dir}" 2>/dev/null || true' EXIT INT TERM
+}
+
+refuse_if_guest_active() {
+  if command -v systemctl >/dev/null 2>&1; then
+    if systemctl is-active --quiet "${GUEST_SERVICE}" 2>/dev/null; then
+      fail "${GUEST_SERVICE} is active; refusing guest root mutation"
+    fi
+  fi
+
+  if [ -e "${GUEST_ROOT}" ] && command -v mountpoint >/dev/null 2>&1; then
+    if mountpoint -q "${GUEST_ROOT}" 2>/dev/null; then
+      fail "guest root is a mountpoint; refusing mutation: ${GUEST_ROOT}"
+    fi
+  fi
+}
+
+cleanup_helper_temp() {
+  tmp_root="$1"
+  if [ -e "${tmp_root}" ]; then
+    if [ ! -f "${tmp_root}/${SEED_IN_PROGRESS_MARKER}" ]; then
+      if ! is_empty_dir "${tmp_root}" && [ ! -f "${tmp_root}/${SEED_COMPLETE_MARKER}" ]; then
+        fail "unowned temp root exists; refusing cleanup: ${tmp_root}"
+      fi
+    fi
+    rm -rf "${tmp_root}"
+  fi
+}
+
+cleanup_stale_helper_temps() {
+  for tmp_root in "${GUEST_ROOT}.tmp."*; do
+    [ -e "${tmp_root}" ] || continue
+    cleanup_helper_temp "${tmp_root}"
+  done
+}
+
+preflight_storage_capacity() {
+  df -Pk "${NIX_ON_ROCK_ROOTFS_DIR}" >/dev/null 2>&1 || fail "cannot inspect storage capacity for ${NIX_ON_ROCK_ROOTFS_DIR}"
+  df -Pi "${NIX_ON_ROCK_ROOTFS_DIR}" >/dev/null 2>&1 || true
+}
+
+manifest_value() {
+  key="$1"
+  sed -n "s/^${key}=//p" "${SEED_MANIFEST}" 2>/dev/null | sed -n '1p'
+}
+
+load_seed_manifest() {
+  [ "${MANIFEST_LOADED}" = "1" ] && return 0
+  [ -r "${SEED_MANIFEST}" ] || fail "seed manifest missing: ${SEED_MANIFEST}"
+
+  EXPECTED_SEED_DEVICE="$(manifest_value seed_device)"
+  EXPECTED_SEED_COMPATIBLE="$(manifest_value seed_compatible)"
+  EXPECTED_SEED_REVISION="$(manifest_value seed_revision)"
+  EXPECTED_SEED_ARCHIVE="$(manifest_value seed_archive)"
+  EXPECTED_SEED_SHA256="$(manifest_value seed_sha256)"
+  EXPECTED_SEED_SIZE="$(manifest_value seed_size)"
+  EXPECTED_SEED_SOURCE_URLS="$(manifest_value seed_source_urls)"
+
+  [ -n "${EXPECTED_SEED_COMPATIBLE}" ] || fail "seed manifest missing seed_compatible: ${SEED_MANIFEST}"
+  [ -n "${EXPECTED_SEED_ARCHIVE}" ] || fail "seed manifest missing seed_archive: ${SEED_MANIFEST}"
+  [ -n "${EXPECTED_SEED_SHA256}" ] || fail "seed manifest missing seed_sha256: ${SEED_MANIFEST}"
+  MANIFEST_LOADED=1
+}
+
+device_compatibles() {
+  if [ -n "${DEVICE_COMPATIBLE}" ]; then
+    printf '%s\n' "${DEVICE_COMPATIBLE}"
+    return 0
+  fi
+  [ -r "${DEVICE_COMPATIBLE_FILE}" ] || fail "device compatible file missing: ${DEVICE_COMPATIBLE_FILE}"
+  tr '\000' '\n' < "${DEVICE_COMPATIBLE_FILE}" | sed '/^$/d'
+}
+
+first_device_compatible() {
+  device_compatibles | sed -n '1p'
+}
+
+compatible_matches_seed() {
+  for device_compatible in $(device_compatibles); do
+    for expected in ${EXPECTED_SEED_COMPATIBLE}; do
+      [ "${device_compatible}" = "${expected}" ] && return 0
+    done
+  done
+  return 1
+}
+
+verify_seed_archive_sha() {
+  archive="$1"
+  expected_sha="$2"
+  [ -n "${expected_sha}" ] || fail "missing expected seed sha256 for ${archive}"
+  actual_sha="$(sha256sum "${archive}" | awk '{print $1}')"
+  if [ "${actual_sha}" != "${expected_sha}" ]; then
+    fail "seed archive SHA256 mismatch: expected=${expected_sha} actual=${actual_sha} archive=${archive}"
+  fi
+}
+
+write_seed_contract_marker() {
+  marker="$1"
+  {
+    [ -n "${EXPECTED_SEED_REVISION}" ] && printf 'revision=%s\n' "${EXPECTED_SEED_REVISION}"
+    [ -n "${EXPECTED_SEED_DEVICE}" ] && printf 'device=%s\n' "${EXPECTED_SEED_DEVICE}"
+    [ -n "${EXPECTED_SEED_COMPATIBLE}" ] && printf 'compatible=%s\n' "${EXPECTED_SEED_COMPATIBLE}"
+    [ -n "${EXPECTED_SEED_SHA256}" ] && printf 'sha256=%s\n' "${EXPECTED_SEED_SHA256}"
+    [ -n "${EXPECTED_SEED_SIZE}" ] && printf 'size=%s\n' "${EXPECTED_SEED_SIZE}"
+    [ -n "${EXPECTED_SEED_ARCHIVE}" ] && printf 'archive=%s\n' "${EXPECTED_SEED_ARCHIVE}"
+    [ -n "${EXPECTED_SEED_SOURCE_URLS}" ] && printf 'source=%s\n' "${EXPECTED_SEED_SOURCE_URLS}"
+  } > "${marker}"
+}
+
+resolve_seed_archive() {
+  if [ -n "${SEED_ARCHIVE}" ]; then
+    [ -f "${SEED_ARCHIVE}" ] || fail "configured seed archive missing: ${SEED_ARCHIVE}"
+    if [ -r "${SEED_MANIFEST}" ]; then
+      load_seed_manifest
+      verify_seed_archive_sha "${SEED_ARCHIVE}" "${EXPECTED_SEED_SHA256}"
+    fi
+    printf '%s\n' "${SEED_ARCHIVE}"
+    return 0
+  fi
+
+  load_seed_manifest
+  device_compatible="$(first_device_compatible)"
+  [ -n "${device_compatible}" ] || fail "empty device compatible string from ${DEVICE_COMPATIBLE_FILE}"
+  compatible_matches_seed || fail "seed is for compatible ${EXPECTED_SEED_COMPATIBLE}, not $(device_compatibles | tr '\n' ' ')"
+
+  archive="${SEED_DIR}/${EXPECTED_SEED_ARCHIVE}"
+  [ -f "${archive}" ] || fail "matching guest rootfs seed archive missing: ${archive}"
+  verify_seed_archive_sha "${archive}" "${EXPECTED_SEED_SHA256}"
+  printf '%s\n' "${archive}"
+}
+
+extract_seed_archive() {
+  archive="$1"
+  destination="$2"
+
+  case "${archive}" in
+    *.tar.zst)
+      if tar --help 2>/dev/null | grep -q -- '--zstd'; then
+        tar --zstd -xf "${archive}" -C "${destination}" || fail "extract from seed archive failed"
+      else
+        command -v zstd >/dev/null 2>&1 || fail "zstd is required to extract seed archive: ${archive}"
+        zstd -dc "${archive}" | tar -xf - -C "${destination}" || fail "extract from seed archive failed"
+      fi
+      ;;
+    *) fail "unsupported seed archive format: ${archive}" ;;
+  esac
+}
+
+populate_seed_candidate() {
+  tmp_root="$1"
+
+  if [ -n "${SEED_ROOT}" ] && [ -d "${SEED_ROOT}" ]; then
+    validate_rootfs "${SEED_ROOT}" yes
+    log "seeding guest root from ${SEED_ROOT} to ${tmp_root}"
+    cp -PR "${SEED_ROOT}/." "${tmp_root}/" || fail "copy from seed payload failed"
+    return 0
+  fi
+
+  archive="$(resolve_seed_archive)"
+  log "seeding guest root from ${archive} to ${tmp_root}"
+  extract_seed_archive "${archive}" "${tmp_root}"
+
+  if [ -n "${SEED_ARCHIVE_MARKER}" ] && [ -r "${SEED_ARCHIVE_MARKER}" ]; then
+    cp "${SEED_ARCHIVE_MARKER}" "${tmp_root}/${SEED_CONTRACT_MARKER}" || fail "copy seed archive marker failed"
+  else
+    load_seed_manifest
+    write_seed_contract_marker "${tmp_root}/${SEED_CONTRACT_MARKER}"
+  fi
+}
+
+build_seed_candidate() {
+  tmp_root="$1"
+
+  preflight_storage_capacity
+  cleanup_stale_helper_temps
+  cleanup_helper_temp "${tmp_root}"
+  mkdir -p "${tmp_root}"
+  : > "${tmp_root}/${SEED_IN_PROGRESS_MARKER}"
+
+  populate_seed_candidate "${tmp_root}"
+  validate_rootfs "${tmp_root}" yes
+
+  mkdir -p "${tmp_root}/etc"
+  {
+    printf 'seeded_at=%s\n' "$(date -u +%FT%TZ 2>/dev/null || true)"
+    if [ -r "${tmp_root}/${SEED_CONTRACT_MARKER}" ]; then
+      sed 's/^/seed_/' "${tmp_root}/${SEED_CONTRACT_MARKER}" 2>/dev/null || true
+    fi
+  } > "${tmp_root}/${SEED_COMPLETE_MARKER}"
+  rm -f "${tmp_root}/${SEED_IN_PROGRESS_MARKER}"
+  sync "${tmp_root}" 2>/dev/null || sync
+}
+
+activate_seed_candidate() {
+  tmp_root="$1"
+
+  if [ -d "${GUEST_ROOT}" ]; then
+    is_empty_dir "${GUEST_ROOT}" || fail "guest root became non-empty during seeding: ${GUEST_ROOT}"
+    rmdir "${GUEST_ROOT}" || fail "failed to remove empty guest root before activation: ${GUEST_ROOT}"
+  fi
+
+  mv "${tmp_root}" "${GUEST_ROOT}" || fail "failed to activate seeded guest root"
+  sync "${NIX_ON_ROCK_ROOTFS_DIR}" 2>/dev/null || sync
+  validate_rootfs "${GUEST_ROOT}" no
+  log "seeded guest root is valid: ${GUEST_ROOT}"
+}
+
+seed_guest_root() {
+  tmp_root="${GUEST_ROOT}.tmp.$$"
+  build_seed_candidate "${tmp_root}"
+  activate_seed_candidate "${tmp_root}"
+}
+
+reseed_requested() {
+  [ "${ROCKNIX_GUEST_FORCE_RESEED:-0}" = "1" ] || [ -e "${RESEED_FLAG}" ]
+}
+
+clear_reseed_flag() {
+  [ -e "${RESEED_FLAG}" ] || return 0
+  rm -f "${RESEED_FLAG}" || fail "failed to clear reseed flag: ${RESEED_FLAG}"
+}
+
+reseed_guest_root() {
+  [ -d "${GUEST_ROOT}" ] || fail "cannot reseed missing guest root through reseed path: ${GUEST_ROOT}"
+  is_empty_dir "${GUEST_ROOT}" && fail "cannot reseed empty guest root through reseed path: ${GUEST_ROOT}"
+
+  tmp_root="${GUEST_ROOT}.tmp.$$"
+  previous_root="${NIX_ON_ROCK_PREVIOUS_ROOT}"
+  build_seed_candidate "${tmp_root}"
+
+  if [ -e "${previous_root}" ]; then
+    if ! ( validate_rootfs "${previous_root}" no ) && [ ! -f "${previous_root}/${SEED_COMPLETE_MARKER}" ]; then
+      fail "previous guest root exists and is neither valid nor helper-owned: ${previous_root}"
+    fi
+    rm -rf "${previous_root}" || fail "failed to remove previous guest root: ${previous_root}"
+  fi
+
+  mv "${GUEST_ROOT}" "${previous_root}" || fail "failed to move old guest root aside: ${GUEST_ROOT} -> ${previous_root}"
+  if ! mv "${tmp_root}" "${GUEST_ROOT}"; then
+    mv "${previous_root}" "${GUEST_ROOT}" 2>/dev/null || true
+    fail "failed to activate reseeded guest root"
+  fi
+
+  sync "${NIX_ON_ROCK_ROOTFS_DIR}" 2>/dev/null || sync
+  if ! ( validate_rootfs "${GUEST_ROOT}" no ); then
+    failed_root="${GUEST_ROOT}.failed-reseed.$$"
+    mv "${GUEST_ROOT}" "${failed_root}" 2>/dev/null || true
+    mv "${previous_root}" "${GUEST_ROOT}" 2>/dev/null || true
+    fail "reseeded guest root failed validation; restored previous root and left failed candidate at ${failed_root}"
+  fi
+  clear_reseed_flag
+  log "reseeded guest root is valid: ${GUEST_ROOT}; previous root retained at ${previous_root}"
+}
+
+recover_previous_root_if_needed() {
+  previous_root="${NIX_ON_ROCK_PREVIOUS_ROOT}"
+  if [ ! -d "${GUEST_ROOT}" ] && [ -d "${previous_root}" ]; then
+    log "guest root missing but previous root exists; restoring ${previous_root}"
+    mv "${previous_root}" "${GUEST_ROOT}" || fail "failed to restore previous guest root: ${previous_root}"
+    validate_rootfs "${GUEST_ROOT}" no
+  fi
+}
+
+run_layout_migration() {
+  [ "${ROCKNIX_GUEST_SKIP_LAYOUT_MIGRATION:-0}" = "1" ] && return 0
+  if command -v nix-on-rock-migrate >/dev/null 2>&1; then
+    nix-on-rock-migrate
+    return 0
+  fi
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  if [ -x "${script_dir}/nix-on-rock-migrate" ]; then
+    "${script_dir}/nix-on-rock-migrate"
+  fi
+}
+
+main() {
+  run_layout_migration
+  acquire_lock
+  ensure_safe_storage_paths
+  refuse_if_guest_active
+  recover_previous_root_if_needed
+
+  if [ -d "${GUEST_ROOT}" ]; then
+    if is_empty_dir "${GUEST_ROOT}"; then
+      log "guest root exists but is empty; seeding"
+      seed_guest_root
+      clear_reseed_flag
+      exit 0
+    fi
+
+    if reseed_requested; then
+      log "reseed requested by ${RESEED_FLAG}; replacing guest root"
+      reseed_guest_root
+      exit 0
+    fi
+    validate_rootfs "${GUEST_ROOT}" no
+    if [ ! -f "${GUEST_ROOT}/${SEED_COMPLETE_MARKER}" ]; then
+      log "guest root is valid without seed completion marker; treating as legacy-approved root"
+    else
+      log "guest root is already valid"
+    fi
+    exit 0
+  fi
+
+  log "guest root missing; seeding"
+  seed_guest_root
+  clear_reseed_flag
+}
+
+main "$@"
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-soak b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-soak
new file mode 100755
index 0000000000..e1411eeeb4
--- /dev/null
+++ b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-soak
@@ -0,0 +1,337 @@
+#!/bin/sh
+# SPDX-License-Identifier: GPL-2.0
+# Copyright (C) 2026-present ROCKNIX (https://github.com/ROCKNIX)
+#
+# SM8550 guest standalone soak harness.
+#
+# Samples the guest/main-space runtime invariants every hour.
+# Pass criteria: zero alarms across N hourly samples (default 24).
+#
+# Usage:
+#   rocknix-guest-soak [--hours N] [--interval-seconds S] [--guest-pid PID]
+#
+# Environment overrides:
+#   ROCKNIX_GUEST_ROOT          default /storage/nix-on-rock/rootfs/current
+#   ROCKNIX_GUEST_LOG           default /var/log/rocknix-guest-soak.log
+#   ROCKNIX_GUEST_SUMMARY       default /var/log/rocknix-guest-soak-summary.log
+#   ROCKNIX_REQUIRE_HOST_ESSWAY default auto (yes/no/auto)
+
+set -u
+
+if [ -n "${ROCKNIX_GUEST_PATHS_FILE:-}" ] && [ -r "${ROCKNIX_GUEST_PATHS_FILE}" ]; then
+  . "${ROCKNIX_GUEST_PATHS_FILE}"
+elif [ -r /usr/lib/rocknix-guest-substrate/nix-on-rock-paths ]; then
+  . /usr/lib/rocknix-guest-substrate/nix-on-rock-paths
+else
+  script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+  [ -r "${script_dir}/nix-on-rock-paths" ] && . "${script_dir}/nix-on-rock-paths"
+fi
+
+NIX_ON_ROCK_CURRENT_ROOT="${NIX_ON_ROCK_CURRENT_ROOT:-/storage/nix-on-rock/rootfs/current}"
+NIX_ON_ROCK_MANUAL_HOLD_FILE="${NIX_ON_ROCK_MANUAL_HOLD_FILE:-/storage/nix-on-rock/requests/manual-generation-hold}"
+
+HOURS=24
+INTERVAL=3600
+GUEST_PID=""
+GUEST_ROOT="${ROCKNIX_GUEST_ROOT:-${NIX_ON_ROCK_CURRENT_ROOT}}"
+LOG="${ROCKNIX_GUEST_LOG:-/var/log/rocknix-guest-soak.log}"
+SUMMARY="${ROCKNIX_GUEST_SUMMARY:-/var/log/rocknix-guest-soak-summary.log}"
+REQUIRE_HOST_ESSWAY="${ROCKNIX_REQUIRE_HOST_ESSWAY:-auto}"
+
+while [ $# -gt 0 ]; do
+  case "$1" in
+    --hours) HOURS="$2"; shift 2 ;;
+    --interval-seconds) INTERVAL="$2"; shift 2 ;;
+    --guest-pid) GUEST_PID="$2"; shift 2 ;;
+    -h|--help)
+      grep '^#' "$0" | head -30
+      exit 0
+      ;;
+    *)
+      printf 'unknown arg: %s\n' "$1" >&2
+      exit 2
+      ;;
+  esac
+done
+
+ts() {
+  date -u +%FT%TZ
+}
+
+log() {
+  msg="$(ts) $*"
+  printf '%s\n' "${msg}"
+  printf '%s\n' "${msg}" >> "${LOG}" 2>/dev/null || true
+}
+
+alarm() {
+  log "ALARM: $*"
+  alarms=$((alarms + 1))
+}
+
+# Find the guest's outer nspawn PID (and through it the inner PID 1).
+resolve_guest_pid() {
+  if [ -n "${GUEST_PID}" ]; then
+    printf '%s\n' "${GUEST_PID}"
+    return 0
+  fi
+  pid=$(systemctl show -p MainPID --value rocknix-guest.service 2>/dev/null)
+  if [ -z "${pid}" ] || [ "${pid}" = "0" ]; then
+    pid=$(systemctl show -p MainPID --value rocknix-guest.service 2>/dev/null)
+  fi
+  printf '%s\n' "${pid}"
+}
+
+guest_inner_pid() {
+  outer=$1
+  [ -n "${outer}" ] && [ "${outer}" != "0" ] || return 1
+  pgrep -P "${outer}" 2>/dev/null | head -1
+}
+
+# 8 hourly checks. Each emits a single line in the summary log.
+check_resolv_owned() {
+  inner=$1
+  marker="${GUEST_ROOT}/etc/resolv.conf.guest-owned"
+  if [ ! -f "${marker}" ]; then
+    alarm "resolv.conf ownership marker missing at ${marker}"
+    return
+  fi
+
+  # The guest owns /etc/resolv.conf and may make it an absolute symlink
+  # inside its own root (for example /etc/static/resolv.conf -> /nix/store/...).
+  # Test from the guest mount namespace when possible so host path resolution
+  # does not turn a valid guest symlink into a false missing-file alarm.
+  if [ -n "${inner}" ] && command -v nsenter >/dev/null 2>&1; then
+    if ! nsenter -t "${inner}" -m -u -i -n -p /bin/sh -c '[ -e /etc/resolv.conf ]' 2>/dev/null; then
+      alarm "guest /etc/resolv.conf missing"
+      return
+    fi
+    if nsenter -t "${inner}" -m -u -i -n -p /bin/sh -c "grep -q '# Generated by resolvconf' /etc/resolv.conf" 2>/dev/null; then
+      alarm "guest /etc/resolv.conf clobbered by host resolvconf"
+    fi
+    return
+  fi
+
+  resolv="${GUEST_ROOT}/etc/resolv.conf"
+  if [ ! -e "${resolv}" ]; then
+    alarm "guest /etc/resolv.conf missing"
+    return
+  fi
+  if grep -q '# Generated by resolvconf' "${resolv}" 2>/dev/null; then
+    alarm "guest /etc/resolv.conf clobbered by host resolvconf"
+  fi
+}
+
+resolve_guest_profile() {
+  profile_guest_path=$1
+  profile_path="${GUEST_ROOT}${profile_guest_path}"
+  [ -L "${profile_path}" ] || return 1
+  target=$(readlink "${profile_path}" 2>/dev/null || true)
+  case "${target}" in
+    /nix/*) resolved="${target}" ;;
+    '') return 1 ;;
+    *) resolved=$(readlink "$(dirname "${profile_path}")/${target}" 2>/dev/null || true) ;;
+  esac
+  case "${resolved}" in /nix/*) : ;; *) return 1 ;; esac
+  [ -x "${GUEST_ROOT}${resolved}/init" ] || return 1
+  printf '%s\n' "${resolved}"
+}
+
+check_selected_system_profile() {
+  inner=$1
+  if command -v rocknix-guest-activation-audit >/dev/null 2>&1; then
+    if ! rocknix-guest-activation-audit --quiet; then
+      alarm "guest activation audit failed"
+    fi
+    if [ -e "${ROCKNIX_GUEST_MANUAL_HOLD_FILE:-${NIX_ON_ROCK_MANUAL_HOLD_FILE}}" ]; then
+      log "  manual generation hold is active"
+    fi
+    return
+  fi
+
+  selected_profile="${ROCKNIX_GUEST_SYSTEM_PROFILE:-/nix/var/nix/profiles/per-user/root/rocknix-guest-system}"
+
+  selected=$(resolve_guest_profile "${selected_profile}" || true)
+
+  if [ -z "${selected}" ]; then
+    alarm "no valid selected guest system profile"
+  fi
+
+  [ -n "${inner}" ] || return 0
+  running=$(readlink "/proc/${inner}/root/run/current-system" 2>/dev/null || true)
+  expected="${selected:-}"
+  if [ -z "${running}" ]; then
+    alarm "guest /run/current-system not seeded (inner pid=${inner})"
+  elif [ -n "${expected}" ] && [ "${running}" != "${expected}" ]; then
+    alarm "guest /run/current-system drifted from selected profile: running=${running} expected=${expected}"
+  fi
+}
+
+check_run_current_system() {
+  inner=$1
+  check_selected_system_profile "${inner}"
+}
+
+check_no_host_usr_in_guest_path() {
+  inner=$1
+  [ -n "${inner}" ] || return 0
+  guest_path=$(awk -F= '/^PATH=/ {print $2; exit}' "/proc/${inner}/environ" 2>/dev/null | tr '\0' '\n' | head -1)
+  case "${guest_path}" in
+    *":/usr/bin"*|"/usr/bin"*|*":/usr/sbin"*|"/usr/sbin"*)
+      # Allow these only if they are the GUEST's /usr (NixOS guests use
+      # /run/current-system/sw/bin etc.; raw /usr/bin in PATH suggests
+      # a host /usr leak via bind).
+      alarm "guest PATH contains raw /usr/bin or /usr/sbin: ${guest_path}"
+      ;;
+  esac
+}
+
+check_guest_sway_alive() {
+  inner=$1
+  [ -n "${inner}" ] || return 0
+  if ! pgrep -P "${inner}" --ns "${inner}" >/dev/null 2>&1; then
+    # Fallback: just confirm there's at least one descendant process.
+    if [ -z "$(ls "/proc/${inner}/task" 2>/dev/null)" ]; then
+      alarm "guest inner pid ${inner} has no tasks"
+      return
+    fi
+  fi
+  # Soft check for sway in the guest's pid namespace via /proc walk.
+  found=$(grep -h '^Name:' /proc/[0-9]*/status 2>/dev/null | awk '$2=="sway"' | head -1)
+  if [ -z "${found}" ]; then
+    alarm "no sway process anywhere on system (guest sway expected)"
+  fi
+}
+
+check_guest_pipewire_alive() {
+  found=$(grep -h '^Name:' /proc/[0-9]*/status 2>/dev/null | awk '$2=="pipewire"' | head -1)
+  if [ -z "${found}" ]; then
+    alarm "no pipewire process (guest pipewire expected)"
+  fi
+}
+
+check_host_essway_alive() {
+  case "${REQUIRE_HOST_ESSWAY}" in
+    yes)
+      :
+      ;;
+    no)
+      log "  host essway check skipped (SSH-first recovery contract)"
+      return
+      ;;
+    auto)
+      if ! systemctl list-unit-files essway.service >/dev/null 2>&1; then
+        log "  host essway check skipped (essway.service not installed)"
+        return
+      fi
+      ;;
+    *)
+      alarm "invalid ROCKNIX_REQUIRE_HOST_ESSWAY=${REQUIRE_HOST_ESSWAY} (expected yes/no/auto)"
+      return
+      ;;
+  esac
+
+  if ! systemctl is-active --quiet essway.service 2>/dev/null; then
+    alarm "host essway.service not active (legacy UI recovery plane expected)"
+  fi
+}
+
+check_host_ssh_responsive() {
+  # Localhost SSH proves that the recovery daemon is reachable. The host does
+  # not need to have a private key for itself; an authentication refusal after
+  # banner/key exchange is still a responsive SSH server.
+  output=$(timeout 5 ssh -o BatchMode=yes -o ConnectTimeout=3 \
+      -o StrictHostKeyChecking=no \
+      -o UserKnownHostsFile=/dev/null \
+      -o GlobalKnownHostsFile=/dev/null \
+      -o PreferredAuthentications=publickey \
+      root@127.0.0.1 true 2>&1)
+  status=$?
+  if [ "${status}" -eq 0 ]; then
+    return
+  fi
+  if printf '%s\n' "${output}" | grep -q 'Permission denied'; then
+    log "  host SSH on :22 responded (authentication refused as expected)"
+    return
+  fi
+  alarm "host SSH on :22 not responsive to BatchMode probe"
+}
+
+check_memory_no_growth() {
+  cur=$(awk '/^MemAvailable:/ {print $2}' /proc/meminfo)
+  if [ -z "${cur}" ]; then
+    alarm "could not read MemAvailable"
+    return
+  fi
+  if [ -z "${baseline_mem:-}" ]; then
+    baseline_mem=$cur
+    log "  baseline MemAvailable=${baseline_mem} kB"
+    return
+  fi
+  delta=$((baseline_mem - cur))
+  if [ "${delta}" -gt 204800 ]; then
+    alarm "MemAvailable dropped by ${delta} kB from baseline ${baseline_mem} kB (>200MB)"
+  fi
+}
+
+run_one_sample() {
+  hour=$1
+  log "== sample h${hour} =="
+  outer=$(resolve_guest_pid)
+  inner=$(guest_inner_pid "${outer}")
+  log "  guest outer=${outer:-none} inner=${inner:-none}"
+
+  if [ -z "${outer}" ] || [ "${outer}" = "0" ]; then
+    alarm "rocknix-guest.service not active"
+    return
+  fi
+
+  check_resolv_owned "${inner}"
+  check_run_current_system "${inner}"
+  check_no_host_usr_in_guest_path "${inner}"
+  check_guest_sway_alive "${inner}"
+  check_guest_pipewire_alive
+  check_host_essway_alive
+  check_host_ssh_responsive
+  check_memory_no_growth
+}
+
+write_summary() {
+  outcome=$1
+  {
+    printf '%s soak %s after %s/%s samples; alarms=%s\n' \
+      "$(ts)" "${outcome}" "${samples_run}" "${HOURS}" "${alarms}"
+    printf '  log=%s\n' "${LOG}"
+  } > "${SUMMARY}" 2>/dev/null || true
+}
+
+trap 'write_summary INTERRUPTED; exit 130' INT TERM HUP
+
+alarms=0
+samples_run=0
+log "rocknix-guest-soak start hours=${HOURS} interval=${INTERVAL}s log=${LOG}"
+
+# Sample at h0 (immediate baseline), then every INTERVAL up to HOURS samples.
+run_one_sample 0
+samples_run=1
+
+while [ "${samples_run}" -lt "${HOURS}" ]; do
+  if [ "${alarms}" -gt 0 ]; then
+    log "alarm threshold breached after ${samples_run} samples; aborting"
+    write_summary FAIL
+    exit 1
+  fi
+  sleep "${INTERVAL}"
+  run_one_sample "${samples_run}"
+  samples_run=$((samples_run + 1))
+done
+
+if [ "${alarms}" -gt 0 ]; then
+  log "soak completed with ${alarms} alarms"
+  write_summary FAIL
+  exit 1
+fi
+
+log "soak passed: ${samples_run} samples, zero alarms"
+write_summary PASS
+exit 0
diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-start b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/scripts/rocknix-guest-start
