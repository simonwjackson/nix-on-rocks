diff --git a/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-recovery-toggle.service b/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/system.d/rocknix-recovery-toggle.service
