+read_seed_manifest_value() {
+  local manifest="$1"
+  local key="$2"
+  sed -n "s/^${key}=//p" "${manifest}" 2>/dev/null | sed -n '1p'
+}
+
+stage_guest_rootfs_seed_update() {
+  local system_root="${ROCKNIX_UPDATE_SYSTEM_ROOT:-/update}"
+  local storage_root="${ROCKNIX_UPDATE_STORAGE_ROOT:-/storage}"
+  local compatible_file="${ROCKNIX_UPDATE_DEVICE_COMPATIBLE_FILE:-/proc/device-tree/compatible}"
+  local manifest="${system_root}/usr/lib/rocknix-guest-substrate/guest-rootfs-seed.manifest"
+  local seed_archive seed_sha seed_size seed_compatible seed_source seed_target seed_tmp storage_free actual_sha device_compatible expected_compatible matched
+
+  [ -f "${manifest}" ] || return 0
+
+  seed_archive="$(read_seed_manifest_value "${manifest}" seed_archive)"
+  seed_sha="$(read_seed_manifest_value "${manifest}" seed_sha256)"
+  seed_size="$(read_seed_manifest_value "${manifest}" seed_size)"
+  seed_compatible="$(read_seed_manifest_value "${manifest}" seed_compatible)"
+  [ -n "${seed_archive}" ] || { echo "Guest rootfs seed manifest is missing seed_archive"; return 1; }
+  [ -n "${seed_sha}" ] || { echo "Guest rootfs seed manifest is missing seed_sha256"; return 1; }
+  [ -n "${seed_compatible}" ] || { echo "Guest rootfs seed manifest is missing seed_compatible"; return 1; }
+
+  matched="no"
+  if [ -r "${compatible_file}" ]; then
+    for device_compatible in $(tr '\000' '\n' < "${compatible_file}" | sed '/^$/d'); do
+      for expected_compatible in ${seed_compatible}; do
+        [ "${device_compatible}" = "${expected_compatible}" ] && matched="yes"
+      done
+    done
+  fi
+  if [ "${matched}" != "yes" ]; then
+    echo "Guest rootfs seed is for compatible ${seed_compatible}, not this device."
+    return 1
+  fi
+
+  seed_source="${UPDATE_DIR}/seed/${seed_archive}"
+  if [ ! -f "${seed_source}" ]; then
+    case "${UPDATE_FILENAME}" in
+      *.tar) echo "Missing guest rootfs seed payload in update tar: target/seed/${seed_archive}"; return 1 ;;
+      *) echo "Guest rootfs seed payload not present in image update; skipping seed staging"; return 0 ;;
+    esac
+  fi
+
+  [ -n "${seed_size}" ] || seed_size="$(stat -Lt "${seed_source}" | awk '{print $2}')"
+  storage_free="$(df "${storage_root}/" | awk '/[0-9]%/{print $4}')"
+  storage_free=$(( storage_free * 1024 ))
+  if [ "${storage_free}" -lt "${seed_size}" ]; then
+    echo "Not enough free /storage space to stage guest rootfs seed."
+    echo "Need ${seed_size} bytes free while the update archive is still present; have ${storage_free}."
+    return 1
+  fi
+
+  mkdir -p "${storage_root}/nix-on-rock/images/seeds" || return 1
+  seed_target="${storage_root}/nix-on-rock/images/seeds/${seed_archive}"
+  seed_tmp="${seed_target}.tmp"
+  rm -f "${seed_tmp}"
+
+  StartProgress spinner "Staging guest rootfs seed... "
+    if ! cp "${seed_source}" "${seed_tmp}"; then
+      rm -f "${seed_tmp}"
+      StopProgress "FAILED"
+      echo "Guest rootfs seed copy failed."
+      return 1
+    fi
+    sync "${seed_tmp}" 2>/dev/null || sync
+    actual_sha="$(sha256sum "${seed_tmp}" | awk '{print $1}')"
+  if [ "${actual_sha}" = "${seed_sha}" ]; then
+    mv "${seed_tmp}" "${seed_target}"
+    sync "${seed_target}" 2>/dev/null || sync
+    StopProgress "OK"
+    return 0
+  fi
+
+  rm -f "${seed_tmp}"
+  StopProgress "FAILED"
+  echo "Guest rootfs seed SHA256 mismatch."
+  echo "  expected: ${seed_sha}"
+  echo "  actual:   ${actual_sha}"
+  return 1
+}
