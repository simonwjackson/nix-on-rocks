   # systemd-nspawn ships only for explicit Nix-on-ROCK guest-substrate lanes.
-  # Preserve SM8550 behavior; admit RK3566 only when the substrate prerequisite
-  # lane is selected so normal RK3566 images remain lean.
-  case "${DEVICE}:${RK3566_GUEST_SUBSTRATE:-no}" in
