diff --git a/projects/ROCKNIX/devices/RK3326/options b/projects/ROCKNIX/devices/RK3326/options
index f2fbd9543d..cd8515f5b0 100644
--- a/projects/ROCKNIX/devices/RK3326/options
+++ b/projects/ROCKNIX/devices/RK3326/options
@@ -85,6 +85,16 @@
   # close to the existing thin-host image lanes: recovery networking, SSH,
   # boot/storage/update substrate, RK915 Wi-Fi, and no host UX/emulator stack.
     RK3326_R36TMAX_MINIMAL_HOST="${RK3326_R36TMAX_MINIMAL_HOST:-no}"
+
+  # R36T Max product payload lane. This uses the same thin host as the recovery
+  # image, then boots the seeded NixOS guest through rocknix-guest-substrate.
+    RK3326_R36TMAX_GUEST_SUBSTRATE="${RK3326_R36TMAX_GUEST_SUBSTRATE:-no}"
+    if [ "${RK3326_R36TMAX_GUEST_SUBSTRATE}" = "yes" ]; then
+      RK3326_R36TMAX_MINIMAL_HOST="yes"
+      SYSTEMD_DEFAULT_HIERARCHY="${SYSTEMD_DEFAULT_HIERARCHY:-unified}"
+      EXTRA_CMDLINE="${EXTRA_CMDLINE} systemd.unified_cgroup_hierarchy=1 cgroup_no_v1=all"
+    fi
+
     if [ "${RK3326_R36TMAX_MINIMAL_HOST}" = "yes" ]; then
       VULKAN_SUPPORT="no"
       VULKAN="no"
diff --git a/projects/ROCKNIX/packages/sysutils/systemd/package.mk b/projects/ROCKNIX/packages/sysutils/systemd/package.mk
