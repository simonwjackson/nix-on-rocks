diff --git a/scripts/mkimage b/scripts/mkimage
index d581fb2dc2..f86b3edf95 100755
--- a/scripts/mkimage
+++ b/scripts/mkimage
@@ -132,7 +132,14 @@ alias mmd='mmd -i "${IMG_TMP}/part1.fat"'
 # create filesystem on part1
 echo "image: creating filesystem on part1..."
 
-if [ "${BOOTLOADER}" = "syslinux" -o "${BOOTLOADER}" = "bcm2835-bootloader" -o "${BOOTLOADER}" = "u-boot" -o "${BOOTLOADER}" = "arm-efi" -o "${BOOTLOADER}" = "qcom-abl" ]; then
+if [ "${BOOTLOADER}" = "qcom-abl" ]; then
+  # qcom-abl images are flashed onto UFS partitions that report 4096-byte
+  # logical sectors. The Linux FAT driver refuses to mount a filesystem whose
+  # logical sector size is smaller than the underlying device, so format with
+  # -S 4096 (matching installtointernal). 4 sectors/cluster = 16KiB clusters,
+  # giving >65525 clusters at the smallest deployed partition size.
+  mkfs.vfat -F 32 -S 4096 -s 4 -i "${UUID_SYSTEM//-/}" -n "${DISTRO_BOOTLABEL}" "${IMG_TMP}/part1.fat" >"${SAVE_ERROR}" 2>&1 || show_error
+elif [ "${BOOTLOADER}" = "syslinux" -o "${BOOTLOADER}" = "bcm2835-bootloader" -o "${BOOTLOADER}" = "u-boot" -o "${BOOTLOADER}" = "arm-efi" ]; then
   mkfs.vfat -F 32 -S 512 -s 32 -i "${UUID_SYSTEM//-/}" -n "${DISTRO_BOOTLABEL}" "${IMG_TMP}/part1.fat" >"${SAVE_ERROR}" 2>&1 || show_error
 fi
 sync
