@@ -0,0 +1,30 @@
+# SPDX-License-Identifier: GPL-2.0
+# Experimental Rockchip RK915 SDIO Wi-Fi driver for R36T Max bring-up.
+
+PKG_NAME="rk915"
+PKG_VERSION="590fe1dd3fa9569117317b2e0dcbe02c42f8419e"
+PKG_LICENSE="GPL"
+PKG_SITE="https://github.com/stolen/rk915"
+PKG_URL="${PKG_SITE}.git"
+PKG_LONGDESC="Rockchip RK915 SDIO Wi-Fi driver"
+PKG_TOOLCHAIN="make"
+PKG_IS_KERNEL_PKG="yes"
+
+pre_make_target() {
+  unset LDFLAGS
+}
+
+make_target() {
+  make V=1 \
+       -C $(kernel_path) \
+       M=${PKG_BUILD} \
+       ARCH=${TARGET_KERNEL_ARCH} \
+       CROSS_COMPILE=${TARGET_KERNEL_PREFIX} \
+       CONFIG_RK915=m \
+       modules
+}
+
+makeinstall_target() {
+  mkdir -p ${INSTALL}/$(get_full_module_dir)/kernel/drivers/net/wireless/rk915
+    cp -av rk915.ko ${INSTALL}/$(get_full_module_dir)/kernel/drivers/net/wireless/rk915/
+}
