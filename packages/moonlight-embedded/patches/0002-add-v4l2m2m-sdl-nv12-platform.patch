+++ b/CMakeLists.txt
@@ -26,6 +26,7 @@ find_package(PkgConfig REQUIRED)
 option(ENABLE_SDL "Compile SDL support" ON)
 option(ENABLE_FFMPEG "Compile FFMPEG support" ON)
 option(ENABLE_FFMPEG_DRM "Compile FFmpeg V4L2 + DRM PRIME display backend" ON)
+option(ENABLE_V4L2M2M "Compile SM8550 V4L2 M2M hardware decode + SDL NV12 backend" ON)
 option(ENABLE_X11 "Compile X11 support (requires ENABLE_FFMPEG)" ON)
