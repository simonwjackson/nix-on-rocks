@@ -183,6 +184,20 @@ if(ENABLE_FFMPEG_DRM AND AVCODEC_FOUND AND AVUTIL_FOUND AND DRM_LIBRARY)
   message(STATUS "FFmpeg DRM PRIME backend enabled")
 endif()
 
+if(ENABLE_V4L2M2M AND AVCODEC_FOUND AND AVUTIL_FOUND AND DRM_LIBRARY AND EGL_FOUND AND GLES_FOUND AND SDL_FOUND)
+  list(APPEND MOONLIGHT_DEFINITIONS HAVE_V4L2M2M)
