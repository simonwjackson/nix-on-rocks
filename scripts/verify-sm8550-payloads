#!/usr/bin/env bash
set -euo pipefail

repo_root=$(CDPATH="" cd -- "$(dirname -- "$0")/.." && pwd)
work_dir=${NIX_ON_ROCKS_WORKDIR:-"${repo_root}/work/rocknix"}
target_dir=${1:-"${work_dir}/target"}
package_mk="${work_dir}/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk"
manifest=${NIX_ON_ROCKS_BUILD_MANIFEST:-"${repo_root}/nix-on-rocks-build-manifest.md"}

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

[ -d "${target_dir}" ] || fail "missing target directory: ${target_dir}"
[ -f "${package_mk}" ] || fail "missing patched package.mk: ${package_mk}"

budget_mib=$(sed -n \
  -e 's/.*SM8550_FLASH_PARTITION_BUDGET_MIB:-\([0-9][0-9]*\).*/\1/p' \
  -e 's/^[[:space:]]*SM8550_FLASH_PARTITION_BUDGET_MIB="\{0,1\}\([0-9][0-9]*\).*/\1/p' \
  "${work_dir}/projects/ROCKNIX/devices/SM8550/options" | head -1)
[ -n "${budget_mib}" ] || fail "unable to parse SM8550_FLASH_PARTITION_BUDGET_MIB"

mapfile -t update_tars < <(find "${target_dir}" -maxdepth 1 -name 'ROCKNIX-*.tar' | sort)
[ "${#update_tars[@]}" -eq 1 ] || fail "expected exactly one SM8550 update tar, found ${#update_tars[@]}"
update_tar=${update_tars[0]}

tar_listing=$(mktemp)
tar_verbose_listing=$(mktemp)
trap 'rm -f "${tar_listing}" "${tar_verbose_listing}"' EXIT
tar -tf "${update_tar}" > "${tar_listing}"
tar -tvf "${update_tar}" > "${tar_verbose_listing}"

system_bytes=$(awk '$NF ~ /(^|\/)target\/SYSTEM$/ { print $3; exit }' "${tar_verbose_listing}")
[ -n "${system_bytes}" ] || fail "${update_tar} does not contain target/SYSTEM"
budget_bytes=$((budget_mib * 1024 * 1024))
[ "${system_bytes}" -le "${budget_bytes}" ] || fail "${update_tar} target/SYSTEM exceeds SM8550 SYSTEM budget: ${system_bytes} > ${budget_bytes}"

grep -Eq '(^|/)target/SYSTEM$' "${tar_listing}" || fail "${update_tar} missing target/SYSTEM"
grep -Eq '(^|/)target/KERNEL$' "${tar_listing}" || fail "${update_tar} missing target/KERNEL"

expected_seed=$(sed -n 's/^PKG_NIX_GUEST_ROOTFS_SEED_ARCHIVE="\{0,1\}\([^" ]*\)"\{0,1\}$/\1/p' "${package_mk}" | sed -n '1p')
expected_seed_sha=$(sed -n 's/^PKG_NIX_GUEST_ROOTFS_SEED_SHA256="\{0,1\}\([^" ]*\)"\{0,1\}$/\1/p' "${package_mk}" | sed -n '1p')
[ -n "${expected_seed}" ] || fail "unable to parse expected SM8550 guest seed archive"
[ -n "${expected_seed_sha}" ] || fail "unable to parse expected SM8550 guest seed SHA256"

seed_entry=$(awk -v want="target/seed/${expected_seed}" '{ suffix="/" want; if ($0 == want || (length($0) >= length(suffix) && substr($0, length($0) - length(suffix) + 1) == suffix)) { print; exit } }' "${tar_listing}")
[ -n "${seed_entry}" ] || fail "${update_tar} missing expected SM8550 guest seed payload: target/seed/${expected_seed}"
actual_seed_sha=$(tar -xOf "${update_tar}" "${seed_entry}" | sha256sum | awk '{print $1}')
[ "${actual_seed_sha}" = "${expected_seed_sha}" ] || fail "${update_tar}:${seed_entry} SHA256 mismatch: ${actual_seed_sha} != ${expected_seed_sha}"

shopt -s nullglob
for image_file in "${target_dir}"/ROCKNIX-*.img.gz; do
  gzip -t "${image_file}"
done
for checksum in "${target_dir}"/ROCKNIX-*.img.gz.sha256 "${target_dir}"/ROCKNIX-*.tar.sha256; do
  (cd "${target_dir}" && sha256sum -c "$(basename "${checksum}")")
done

if [ -f "${manifest}" ]; then
  grep -q "${expected_seed}" "${manifest}" || fail "manifest missing expected guest seed ${expected_seed}: ${manifest}"
  grep -q "${expected_seed_sha}" "${manifest}" || fail "manifest missing expected guest seed SHA256 ${expected_seed_sha}: ${manifest}"
fi

printf 'Verified SM8550 payloads in %s\n' "${target_dir}"
