#!/usr/bin/env bash
set -euo pipefail

repo_root=$(CDPATH="" cd -- "$(dirname -- "$0")/.." && pwd)
work_dir=${NIX_ON_ROCKS_WORKDIR:-"${repo_root}/work/rocknix"}

[ -d "${work_dir}/.git" ] || { echo "missing patched ROCKNIX checkout: ${work_dir}" >&2; exit 1; }

required=(
  projects/ROCKNIX/devices/RK3566/options
  projects/ROCKNIX/devices/RK3566/linux/linux.aarch64.conf
  projects/ROCKNIX/packages/sysutils/systemd/package.mk
  projects/ROCKNIX/packages/virtual/image/package.mk
  projects/ROCKNIX/packages/virtual/network/package.mk
  projects/ROCKNIX/packages/network/openssh/package.mk
  projects/ROCKNIX/packages/graphics/waffle/package.mk
  projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk
  projects/ROCKNIX/packages/tools/rocknix-guest-substrate/tests/guest-substrate-static-checks.sh
)
repo_required=(
  .github/workflows/build-rk3566.yml
  scripts/verify-rk3566-payloads
  scripts/tests/rk3566-payload-contract.sh
)

for path in "${required[@]}"; do
  [ -e "${work_dir}/${path}" ] || { echo "missing expected patched file: ${path}" >&2; exit 1; }
done
for path in "${repo_required[@]}"; do
  [ -e "${repo_root}/${path}" ] || { echo "missing expected RK3566 repo file: ${path}" >&2; exit 1; }
done

(
  cd "${work_dir}"
  static_checks=projects/ROCKNIX/packages/tools/rocknix-guest-substrate/tests/guest-substrate-static-checks.sh

  grep -q 'RK3566_GUEST_SUBSTRATE="${RK3566_GUEST_SUBSTRATE:-no}"' projects/ROCKNIX/devices/RK3566/options
  grep -q 'SM8550:\*|RK3566:yes' projects/ROCKNIX/packages/virtual/image/package.mk
  grep -q 'SM8550:\*|RK3566:yes' projects/ROCKNIX/packages/sysutils/systemd/package.mk
  grep -q 'supported lanes: SM8550, RK3566 with RK3566_GUEST_SUBSTRATE=yes' projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk
  grep -q 'WAFFLE_GLX="disabled"' projects/ROCKNIX/packages/graphics/waffle/package.mk
  grep -q -- '-Dglx=${WAFFLE_GLX}' projects/ROCKNIX/packages/graphics/waffle/package.mk
  grep -q 'PKG_DEPENDS_TARGET="toolchain iwd networkmanager netbase ethtool openssh iw wireless-regdb rsync nss-mdns"' projects/ROCKNIX/packages/virtual/network/package.mk
  grep -q 'enable_service sshd.service' projects/ROCKNIX/packages/network/openssh/package.mk
  grep -q 'RK3566_GUEST_SUBSTRATE:-no.*yes' projects/ROCKNIX/packages/network/openssh/package.mk
  for rk3566_minimal_setting in \
    'VULKAN_SUPPORT="no"' 'VULKAN="no"' 'PIPEWIRE_SUPPORT="no"' \
    'BLUETOOTH_SUPPORT="no"' 'AVAHI_DAEMON="no"' 'REMOTE_SUPPORT="no"' \
    'JOYSTICK_SUPPORT="no"' 'DEBUG_PACKAGES="no"' 'NFS_SUPPORT="no"' \
    'SAMBA_SERVER="no"' 'SFTP_SERVER="no"' 'SIMPLE_HTTP_SERVER="no"' \
    'ZEROTIER_SUPPORT="no"' 'WIREGUARD_SUPPORT="no"' 'HTOP_TOOL="no"' \
    'BTOP_TOOL="no"'; do
    grep -q "${rk3566_minimal_setting}" projects/ROCKNIX/devices/RK3566/options
  done
  for forbidden_minimal_payload in \
    debug nvtop apitrace waffle nfs-utils htop btop vulkan-tools \
    pipewire wireplumber pulseaudio bluez samba simple-http-server zerotier-one; do
    grep -q "${forbidden_minimal_payload}" projects/ROCKNIX/packages/virtual/image/package.mk
  done
  grep -q 'RK3566_OPTIONS=' "${static_checks}"
  grep -q 'RK3566_GUEST_SUBSTRATE=yes' "${static_checks}"
  grep -q 'CONFIG_USER_NS=y' "${static_checks}"

  for required_config in \
    CONFIG_CGROUPS=y CONFIG_MEMCG=y CONFIG_CGROUP_PIDS=y CONFIG_CGROUP_FREEZER=y \
    CONFIG_CGROUP_DEVICE=y CONFIG_CGROUP_BPF=y CONFIG_NAMESPACES=y CONFIG_UTS_NS=y \
    CONFIG_IPC_NS=y CONFIG_USER_NS=y CONFIG_PID_NS=y CONFIG_NET_NS=y \
    CONFIG_OVERLAY_FS=y CONFIG_TMPFS_POSIX_ACL=y; do
    grep -q "^${required_config}$" projects/ROCKNIX/devices/RK3566/linux/linux.aarch64.conf
  done

  git diff --check
)

grep -q 'name: Build RK3566 SD image' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'DEVICE: RK3566' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'RK3566_GUEST_SUBSTRATE: "yes"' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'NIX_ON_ROCKS_PRODUCT: rg353m' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'scripts/verify-rk3566-payloads' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'actions/cache/restore@v4' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'actions/cache/save@v4' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'ccache-aarch64-RK3566.tar' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'rk3566-ccache-${{ runner.os }}-' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q 'Hardware boot remains unverified until RG353M post-arrival acceptance' "${repo_root}/.github/workflows/build-rk3566.yml"
grep -q '0017-native-arm-host-cflags.patch' "${repo_root}/patches/rocknix/series"
grep -q 'HOST_CPU_CFLAGS' "${repo_root}/patches/rocknix/0017-native-arm-host-cflags.patch"
grep -q 'still extracting guest rootfs seed' "${repo_root}/patches/rocknix/0006-rocknix-guest-substrate.patch"
grep -q 'finished extracting guest rootfs seed' "${repo_root}/patches/rocknix/0006-rocknix-guest-substrate.patch"
grep -q 'FAT label.*ROCKNIX' "${repo_root}/scripts/verify-rk3566-payloads"
grep -q 'extlinux/extlinux.conf' "${repo_root}/scripts/verify-rk3566-payloads"
grep -q 'device_trees.*\.dtb' "${repo_root}/scripts/verify-rk3566-payloads"
grep -q 'STORAGE' "${repo_root}/scripts/verify-rk3566-payloads"
grep -q 'sector 32768' "${repo_root}/scripts/verify-rk3566-payloads"
grep -q 'Verify SM8550 payloads' "${repo_root}/.github/workflows/build-sm8550.yml"
grep -q 'scripts/verify-sm8550-payloads' "${repo_root}/.github/workflows/build-sm8550.yml"
grep -q 'NIX_ON_ROCKS_PRODUCT=rg353m scripts/apply-rocknix-patches' "${repo_root}/.github/workflows/preflight.yml"
grep -q 'scripts/verify-rk3566-contract' "${repo_root}/.github/workflows/preflight.yml"
grep -q 'rk3566-payload-contract.sh' "${repo_root}/scripts/check-shell-smoke"

printf 'Verified patched RK3566 substrate prerequisites and SD artifact lane in %s\n' "${work_dir}"
