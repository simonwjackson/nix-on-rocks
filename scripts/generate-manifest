#!/usr/bin/env bash
# shellcheck disable=SC2016
set -euo pipefail

repo_root=$(CDPATH="" cd -- "$(dirname -- "$0")/.." && pwd)
# shellcheck source=scripts/product-selector
. "${repo_root}/scripts/product-selector"
device=${DEVICE:-SM8550}

if [ "${device}" = "SM8550" ]; then
  select_product_locks "${repo_root}" "$@"
  set -- "${PRODUCT_SELECTOR_ARGS[@]}"
else
  PRODUCT_SELECTOR_ARGS=("$@")
  SELECTED_PRODUCT=""
fi

work_dir=${NIX_ON_ROCKS_WORKDIR:-"${repo_root}/work/rocknix"}
out=${1:-"${repo_root}/nix-on-rocks-build-manifest.md"}
# shellcheck source=../upstream.lock
# shellcheck disable=SC1091,SC2016
. "${repo_root}/upstream.lock"

if [ "${device}" = "SM8550" ]; then
  # shellcheck source=/dev/null
  # shellcheck disable=SC1091,SC2016
  . "${GUEST_LOCK}"
  # shellcheck source=/dev/null
  # shellcheck disable=SC1091,SC2016
  . "${PRODUCT_LOCK}"
fi

patch_hash=$(sha256sum "${repo_root}/patches/rocknix/series" "${repo_root}"/patches/rocknix/*.patch | sha256sum | awk '{print $1}')
product_sha=$(git -C "${repo_root}" rev-parse HEAD 2>/dev/null || echo unknown)

{
  printf '# Nix-on-Rocks %s Build Manifest\n\n' "${device}"
  printf -- '- **Product SHA:** `%s`\n' "${product_sha}"
  printf -- '- **Upstream repo:** `%s`\n' "${UPSTREAM_REPO}"
  printf -- '- **Upstream SHA:** `%s`\n' "${UPSTREAM_SHA}"
  printf -- '- **Source branch SHA:** `%s`\n' "${SOURCE_BRANCH_SHA:-unknown}"
  printf -- '- **Patch-series hash:** `%s`\n' "${patch_hash}"
  printf -- '- **Device:** `%s`\n' "${device}"

  if [ "${device}" = "SM8550" ]; then
    rendered_payload_hash=$("${repo_root}/scripts/render-product-payload" --product "${SELECTED_PRODUCT}" | sha256sum | awk '{print $1}')
    seed_url_authority=${PRODUCT_ROOTFS_SEED_URL:-${PRODUCT_ROOTFS_SEED_URLS%% *}}

    printf -- '- **Rendered product payload hash:** `%s`\n' "${rendered_payload_hash}"
    printf -- '- **Product selector:** `%s`\n' "${SELECTED_PRODUCT}"
    printf -- '- **Accepted compatible:** `%s`\n' "${GUEST_COMPATIBLE}"
    printf -- '- **Guest seed:** `%s`\n' "${GUEST_SEED_ARCHIVE}"
    printf -- '- **Guest seed SHA256:** `%s`\n\n' "${GUEST_SEED_SHA256}"
    printf '## Product Payload\n\n'
    printf -- '- **Authority repo:** `%s`\n' "${PRODUCT_AUTHORITY_REPO}"
    printf -- '- **Product revision:** `%s`\n' "${PRODUCT_REV}"
    printf -- '- **Product source SHA256:** `%s`\n' "${PRODUCT_SOURCE_SHA256}"
    printf -- '- **Product source subdir:** `%s`\n' "${PRODUCT_SOURCE_SUBDIR}"
    printf -- '- **Build target:** `%s`\n' "${PRODUCT_BUILD_TARGET}"
    printf -- '- **Seed revision:** `%s`\n' "${PRODUCT_ROOTFS_SEED_REV}"
    printf -- '- **Seed device:** `%s`\n' "${PRODUCT_ROOTFS_SEED_DEVICE}"
    printf -- '- **Seed compatible:** `%s`\n' "${PRODUCT_ROOTFS_SEED_COMPATIBLE}"
    printf -- '- **Seed archive:** `%s`\n' "${PRODUCT_ROOTFS_SEED_ARCHIVE}"
    printf -- '- **Seed SHA256:** `%s`\n' "${PRODUCT_ROOTFS_SEED_SHA256}"
    printf -- '- **Seed URL authority:** `%s`\n\n' "${seed_url_authority}"
  elif [ "${device}" = "RK3326" ] && [ "${SUBDEVICE:-}" = "R36TMax" ]; then
    printf -- '- **Subdevice:** `%s`\n' "${SUBDEVICE}"
    printf -- '- **Hardware boot:** `verified-r36tmax-rk915-wifi`\n'
    printf -- '- **Artifact contract:** SD-image structure plus forced R36T Max DTB; standalone ROCKNIX proof verified RK915 Wi-Fi over 25 MHz SDIO and SSH reachability.\n\n'
  else
    printf -- '- **Hardware boot:** `unverified`\n'
    printf -- '- **Artifact contract:** SD-image structure only; hardware boot remains unverified until device acceptance evidence exists.\n\n'
  fi

  printf '## Payloads\n\n'
  if [ -d "${work_dir}/target" ]; then
    find "${work_dir}/target" -maxdepth 1 -type f \( -name "ROCKNIX-*${device}*" -o -name "ROCKNIX-*${device}*.sha256" \) -print | sort | while IFS= read -r file; do
      printf -- '- `%s` `%s`\n' "${file#"${work_dir}"/}" "$(sha256sum "${file}" | awk '{print $1}')"
    done
  else
    printf -- '- target directory not present\n'
  fi
} > "${out}"

printf 'Wrote %s\n' "${out}"
