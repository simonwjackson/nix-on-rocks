#!/usr/bin/env bash
set -euo pipefail

repo_root=$(CDPATH="" cd -- "$(dirname -- "$0")/.." && pwd)
# shellcheck source=scripts/product-selector
. "${repo_root}/scripts/product-selector"
stage=${1:?"usage: ci-build-stage <toolchain|base|image>"}
shift

export JAVA_HOME=${JAVA_HOME:-/usr}
export PROJECT=${PROJECT:-ROCKNIX}
export DEVICE=${DEVICE:-SM8550}
export ARCH=${ARCH:-aarch64}
export DISABLE_COLORS=${DISABLE_COLORS:-yes}
export CCACHE_COMPILERCHECK=${CCACHE_COMPILERCHECK:-content}
export CCACHE_COMPRESS=${CCACHE_COMPRESS:-1}
export CCACHE_COMPRESSLEVEL=${CCACHE_COMPRESSLEVEL:-6}
export CCACHE_SLOPPINESS=${CCACHE_SLOPPINESS:-pch_defines,time_macros,include_file_mtime,include_file_ctime}

if [ "${DEVICE}" = "SM8550" ]; then
  select_product_locks "${repo_root}" "$@"
  set -- "${PRODUCT_SELECTOR_ARGS[@]}"
  export NIX_ON_ROCKS_PRODUCT=${SELECTED_PRODUCT}
else
  SELECTED_PRODUCT=""
fi

work_dir=${NIX_ON_ROCKS_WORKDIR:-"${repo_root}/work/rocknix"}
image=${NIX_ON_ROCKS_DOCKER_IMAGE:-nix-on-rocks-rocknix-build:local}
build_dir="${work_dir}/build.${PROJECT}-${DEVICE}.${ARCH}"

archive_ccache() {
  local output=$1
  local max_size=$2
  local ccache_dir="${build_dir}/.ccache"
  local ccache_bin="${build_dir}/toolchain/bin/ccache"

  [ -d "${ccache_dir}" ] || return 0
  if [ -x "${ccache_bin}" ]; then
    CCACHE_DIR="${ccache_dir}" "${ccache_bin}" -s -v || true
    CCACHE_DIR="${ccache_dir}" "${ccache_bin}" -M "${max_size}" || true
    CCACHE_DIR="${ccache_dir}" "${ccache_bin}" -c || true
    CCACHE_DIR="${ccache_dir}" "${ccache_bin}" -z || true
  fi
  tar -C "${work_dir}" --remove-files -cf "${work_dir}/${output}" "./${build_dir#"${work_dir}"/}/.ccache"
}

run_in_container() {
  local command=$1

  cd "${work_dir}"
  ./scripts/get_env > .env

  set +e
  {
    docker run --init --env-file .env --rm \
      --user "$(id -u):$(id -g)" \
      -v "${PWD}:${PWD}" -w "${PWD}" \
      "${image}" bash -lc "${command}"
    echo $? > docker_exit_code
  } | tee output.log | grep -E --color=never --line-buffered '^GET|^UNPACK|^BUILD|^INSTALL' || true
  local exit_code
  exit_code=$(<docker_exit_code)
  set -e
  return "${exit_code}"
}

generate_manifest() {
  local args=()
  if [ -n "${SELECTED_PRODUCT}" ]; then
    args+=(--product "${SELECTED_PRODUCT}")
  fi
  "${repo_root}/scripts/generate-manifest" "${args[@]}"
}

verify_payloads() {
  case "${DEVICE}" in
    SM8550)
      local args=()
      if [ "${NIX_ON_ROCKS_REQUIRE_FULL_IMAGE:-no}" = "yes" ]; then
        args+=(--require-full-image)
      fi
      "${repo_root}/scripts/verify-sm8550-payloads" --product "${SELECTED_PRODUCT}" "${args[@]}" "${work_dir}/target"
      ;;
    RK3566)
      "${repo_root}/scripts/verify-rk3566-payloads" "${work_dir}/target"
      ;;
    *)
      echo "ci-build-stage: no payload verifier for DEVICE=${DEVICE}" >&2
      exit 1
      ;;
  esac
}

case "${stage}" in
  toolchain)
    run_in_container './scripts/build_mt toolchain alsa-lib llvm:host'
    cd "${work_dir}"
    archive_ccache "ccache-aarch64-${DEVICE}-toolchain.tar" 500M
    build_rel="./${build_dir#"${work_dir}"/}"
    tar --zstd -cf build.aarch64-toolchain.tar.zst \
      "${build_rel}/toolchain" \
      "${build_rel}/build" \
      "${build_rel}"/install_* \
      "${build_rel}/.stamps"
    ;;
  base)
    export EMULATION_DEVICE=${EMULATION_DEVICE:-no}
    export ENABLE_32BIT=${ENABLE_32BIT:-no}
    export MODULES_PKG=${MODULES_PKG:-no}
    run_in_container './scripts/build_distro'
    cd "${work_dir}"
    archive_ccache "ccache-aarch64-${DEVICE}.tar" 500M
    if [ "${NIX_ON_ROCKS_SKIP_BASE_ARCHIVE:-no}" = "yes" ]; then
      df -h .
      du -sh "./${build_dir#"${work_dir}"/}" "./${build_dir#"${work_dir}"/}/build" 2>/dev/null || true
      exit 0
    fi
    build_rel="./${build_dir#"${work_dir}"/}"
    tar --zstd --remove-files -cf build.build.aarch64.tar.zst "${build_rel}/build"
    tar --zstd --remove-files -cf build.aarch64.tar.zst "${build_rel}/"
    ;;
  image)
    export NIGHTLY=${NIGHTLY:-yes}
    export OFFICIAL=${OFFICIAL:-no}
    run_in_container './scripts/build_distro'
    generate_manifest
    verify_payloads
    ;;
  manifest)
    generate_manifest
    verify_payloads
    ;;
  *)
    echo "unknown stage: ${stage}" >&2
    exit 1
    ;;
esac
