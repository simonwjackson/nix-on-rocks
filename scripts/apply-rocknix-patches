#!/usr/bin/env bash
set -euo pipefail

repo_root=$(CDPATH="" cd -- "$(dirname -- "$0")/.." && pwd)
# shellcheck source=scripts/product-selector
. "${repo_root}/scripts/product-selector"
device=${DEVICE:-SM8550}
if [ "${device}" = "SM8550" ] \
  || { [ "${device}" = "RK3566" ] && [ "${RK3566_GUEST_SUBSTRATE:-no}" = "yes" ]; } \
  || { [ "${device}" = "RK3326" ] && [ "${RK3326_R36TMAX_GUEST_SUBSTRATE:-no}" = "yes" ]; }; then
  select_product_locks "${repo_root}" "$@"
  set -- "${PRODUCT_SELECTOR_ARGS[@]}"
else
  PRODUCT_SELECTOR_ARGS=("$@")
  SELECTED_PRODUCT=""
fi
work_dir=${NIX_ON_ROCKS_WORKDIR:-"${repo_root}/work/rocknix"}
series="${repo_root}/patches/rocknix/series"

"${repo_root}/scripts/fetch-upstream"

while IFS= read -r patch_name; do
  case "${patch_name}" in
    ''|'#'*) continue ;;
  esac
  patch_path="${repo_root}/patches/rocknix/${patch_name}"
  [ -f "${patch_path}" ] || { echo "missing patch: ${patch_path}" >&2; exit 1; }
  echo "Applying ${patch_name}"
  git -C "${work_dir}" apply --whitespace=nowarn "${patch_path}"
done < "${series}"

git -C "${work_dir}" diff --check
printf 'Applied Nix-on-Rocks patch queue to %s\n' "${work_dir}"

# Stage Nix-on-Rocks-owned contract docs into the rocknix-guest-substrate
# package directory so its post_install can cp them without reaching
# across repos. The docs live in this repo under docs/contracts/; the
# rocknix build runs inside work/rocknix/ and cannot read paths above
# that root, so we mirror the three on-image docs into the patched
# package tree. Patch 0006 references these copies via ${PKG_DIR}/
# contract-docs/<file>.
substrate_pkg_dir="${work_dir}/projects/ROCKNIX/packages/tools/rocknix-guest-substrate"
contract_docs_dest="${substrate_pkg_dir}/contract-docs"
mkdir -p "${contract_docs_dest}"
for doc in layer14-main-space-contract.md layer14-soak-checklist.md HOW-TO-FALL-BACK.md; do
  src="${repo_root}/docs/contracts/${doc}"
  [ -f "${src}" ] || { echo "missing contract doc for substrate stage: ${src}" >&2; exit 1; }
  cp "${src}" "${contract_docs_dest}/${doc}"
done
printf 'Staged Nix-on-Rocks contract docs into %s\n' "${contract_docs_dest}"

payload_env_dest="${substrate_pkg_dir}/product-payload.env"
if [ -n "${SELECTED_PRODUCT}" ]; then
  "${repo_root}/scripts/render-product-payload" --product "${SELECTED_PRODUCT}" > "${payload_env_dest}.tmp"
  mv "${payload_env_dest}.tmp" "${payload_env_dest}"
  printf 'Staged rendered %s product payload environment into %s\n' "${SELECTED_PRODUCT}" "${payload_env_dest}"
else
  printf '# Product payload disabled for DEVICE=%s\n' "${device}" > "${payload_env_dest}"
  printf 'Staged empty product payload environment for DEVICE=%s into %s\n' "${device}" "${payload_env_dest}"
fi

# Stage the payload-supplied boot-splash branding patch. The substrate is
# product-blind here: when the selected product payload pins no branding
# patch, rocknix-splash keeps the upstream ROCKNIX logo. When one is
# pinned, fetch it (or take NIX_ON_ROCKS_BRANDING_SPLASH_PATCH as a local
# file override), verify its SHA256 against the lock, and drop it into
# the rocknix-splash package patch queue.
splash_patch_dir="${work_dir}/projects/ROCKNIX/packages/tools/rocknix-splash/patches"
splash_patch_dest="${splash_patch_dir}/rocknix-splash-0001-product-boot-logo.patch"
rm -f "${splash_patch_dest}"
read_payload_field() {
  env -i bash -c 'set -euo pipefail; . "$1"; printf "%s" "${!2-}"' bash "${payload_env_dest}" "$1"
}
branding_sha=""
if [ -n "${SELECTED_PRODUCT}" ]; then
  branding_sha=$(read_payload_field PKG_NIX_GUEST_BRANDING_SPLASH_PATCH_SHA256)
fi
if [ -n "${branding_sha}" ]; then
  branding_url=$(read_payload_field PKG_NIX_GUEST_BRANDING_SPLASH_PATCH_URL)
  branding_tmp="${splash_patch_dest}.tmp"
  if [ -n "${NIX_ON_ROCKS_BRANDING_SPLASH_PATCH:-}" ]; then
    [ -f "${NIX_ON_ROCKS_BRANDING_SPLASH_PATCH}" ] \
      || { echo "missing branding splash patch override: ${NIX_ON_ROCKS_BRANDING_SPLASH_PATCH}" >&2; exit 1; }
    mkdir -p "${splash_patch_dir}"
    cp "${NIX_ON_ROCKS_BRANDING_SPLASH_PATCH}" "${branding_tmp}"
  elif [ -n "${branding_url}" ]; then
    mkdir -p "${splash_patch_dir}"
    curl --fail --silent --show-error --location --retry 3 --retry-delay 2 \
      --output "${branding_tmp}" "${branding_url}" \
      || { echo "unable to fetch branding splash patch from ${branding_url}" >&2; exit 1; }
  else
    echo "product payload pins a branding splash patch but provides no URL; set NIX_ON_ROCKS_BRANDING_SPLASH_PATCH or pin PRODUCT_BRANDING_SPLASH_PATCH_URL" >&2
    exit 1
  fi
  staged_sha=$(sha256sum "${branding_tmp}" | awk '{print $1}')
  if [ "${staged_sha}" != "${branding_sha}" ]; then
    rm -f "${branding_tmp}"
    echo "branding splash patch SHA256 mismatch: expected ${branding_sha}, got ${staged_sha}" >&2
    exit 1
  fi
  mv "${branding_tmp}" "${splash_patch_dest}"
  printf 'Staged product boot-splash branding patch into %s\n' "${splash_patch_dest}"
else
  printf 'No product boot-splash branding pinned; upstream ROCKNIX splash retained\n'
fi
