#!/usr/bin/env bash
set -euo pipefail

target=${1:-.}
expected_label=${EXPECTED_FLASH_LABEL:-ROCKNIX}
expected_block_size=${EXPECTED_FLASH_BLOCK_SIZE:-4096}

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

read_le16() {
  local file=$1
  local offset=$2
  od -An -v -j "${offset}" -N 2 -tu1 "${file}" | awk '{ print $1 + ($2 * 256) }'
}

read_label() {
  local file=$1
  local offset=$2
  dd if="${file}" bs=1 skip="${offset}" count=11 status=none | tr -d ' '
}

verify_image() {
  local image=$1
  local raw_image=$image
  local tmp=""
  if [[ ${image} == *.gz ]]; then
    tmp=$(mktemp)
    gzip -cd "${image}" > "${tmp}"
    raw_image=${tmp}
  fi

  local found=no
  while IFS= read -r line; do
    [[ ${line} == *start=* ]] || continue
    local start
    start=$(printf '%s\n' "${line}" | sed -n 's/.*start=[[:space:]]*\([0-9][0-9]*\).*/\1/p')
    [ -n "${start}" ] || continue
    local offset=$((start * 512))
    local boot
    boot=$(mktemp)
    dd if="${raw_image}" of="${boot}" bs=1 skip="${offset}" count=512 status=none 2>/dev/null || { rm -f "${boot}"; continue; }

    local label32 label16 label block_size
    label32=$(read_label "${boot}" 71 || true)
    label16=$(read_label "${boot}" 43 || true)
    label=${label32:-${label16}}
    if [ "${label}" = "${expected_label}" ]; then
      found=yes
      block_size=$(read_le16 "${boot}" 11)
      [ "${block_size}" = "${expected_block_size}" ] || fail "${image} ${expected_label} FAT logical sector size mismatch: expected ${expected_block_size}, got ${block_size}"
      printf 'Verified %s FAT label %s logical sector size %s\n' "${image}" "${expected_label}" "${block_size}"
    fi
    rm -f "${boot}"
  done < <(sfdisk -d "${raw_image}" 2>/dev/null || true)

  [ -z "${tmp}" ] || rm -f "${tmp}"
  [ "${found}" = yes ] || fail "${image} missing FAT partition label ${expected_label}"
}

shopt -s nullglob
images=()
if [ -d "${target}" ]; then
  images=("${target}"/ROCKNIX-*.img "${target}"/ROCKNIX-*.img.gz)
else
  images=("${target}")
fi

[ "${#images[@]}" -gt 0 ] || exit 0
command -v sfdisk >/dev/null 2>&1 || fail "sfdisk is required for SM8550 FAT geometry verification"

for image in "${images[@]}"; do
  [ -f "${image}" ] || continue
  verify_image "${image}"
done
