#!/usr/bin/env bash
set -euo pipefail

repo_root=$(CDPATH="" cd -- "$(dirname -- "$0")/.." && pwd)
work_dir=${NIX_ON_ROCKS_WORKDIR:-"${repo_root}/work/rocknix"}
out=${1:-"${repo_root}/sm8550-base-provenance.env"}

hash_file() {
  sha256sum "$1" | awk '{print $1}'
}

hash_stream() {
  sha256sum | awk '{print $1}'
}

rendered_payload_hash=$("${repo_root}/scripts/render-product-payload" | hash_stream)
patch_series_hash=$(sha256sum "${repo_root}/patches/rocknix/series" "${repo_root}"/patches/rocknix/*.patch | hash_stream)
package_mk="${work_dir}/projects/ROCKNIX/packages/tools/rocknix-guest-substrate/package.mk"
[ -f "${package_mk}" ] || { echo "missing patched package.mk: ${package_mk}" >&2; exit 1; }

{
  printf 'SM8550_BASE_PROVENANCE_VERSION=%q\n' "1"
  printf 'PRODUCT_PAYLOAD_LOCK_SHA256=%q\n' "$(hash_file "${repo_root}/product-payload.lock")"
  printf 'GUEST_LOCK_SHA256=%q\n' "$(hash_file "${repo_root}/guest.lock")"
  printf 'RENDERED_PRODUCT_PAYLOAD_SHA256=%q\n' "${rendered_payload_hash}"
  printf 'PATCH_SERIES_SHA256=%q\n' "${patch_series_hash}"
  printf 'UPSTREAM_LOCK_SHA256=%q\n' "$(hash_file "${repo_root}/upstream.lock")"
  printf 'SUBSTRATE_PACKAGE_MK_SHA256=%q\n' "$(hash_file "${package_mk}")"
} > "${out}"

printf 'Wrote %s\n' "${out}"
